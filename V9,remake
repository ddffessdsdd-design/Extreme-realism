	makeSectionLbl(parent, sectionLabel, sectionOrder)
	local selected = default
	local btns = {}
	for i, item in ipairs(items) do
		local b, bs = makeOptBtn(parent, item.label, sectionOrder + i)
		btns[i] = {btn = b, stroke = bs}
		b.MouseButton1Click:Connect(function()
			selected = i
			applySelStyle(btns, selected)
			onSelect(item.value, i)
		end)
	end
	applySelStyle(btns, selected)
	return btns
end

