local function applySelStyle(btns, selected)
for i, bb in ipairs(btns) do
bb.btn.BackgroundColor3 = i==selected and Color3.fromRGB(32,10,10) or Color3.fromRGB(16,8,8)
bb.stroke.Color = i==selected and Color3.fromRGB(160,30,30) or Color3.fromRGB(60,20,20)
bb.btn.TextColor3 = i==selected and Color3.fromRGB(230,170,170) or Color3.fromRGB(180,140,140)
end
end

local function makeSelectGroup(parent, sectionLabel, sectionOrder, items, default, onSelect)
makeSectionLbl(parent, sectionLabel, sectionOrder)
local selected = default; local btns = {}
for i, item in ipairs(items) do
local b, bs = makeOptBtn(parent, item.label, sectionOrder+i)
btns[i] = {btn=b, stroke=bs}
b.MouseButton1Click:Connect(function()
selected = i; applySelStyle(btns, selected); onSelect(item.value, i)
end)
end
applySelStyle(btns, selected); return btns
end

