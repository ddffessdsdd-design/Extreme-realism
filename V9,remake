local sidePanels = {}

local function repositionAllSidePanels()
	local panelAbsPos  = panel.AbsolutePosition
	local panelAbsSize = panel.AbsoluteSize
	local currentX = panelAbsPos.X + panelAbsSize.X + SIDE_GAP
	local topY = panelAbsPos.Y
	for _, entry in ipairs(sidePanels) do
		if entry.isOpen then
			entry.frame.Position = UDim2.new(0, currentX, 0, topY)
			task.wait()
			currentX = currentX + entry.frame.AbsoluteSize.X + SIDE_GAP
		end
	end
end

