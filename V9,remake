local function togglePanel(forceTo)
local target = forceTo
if target == nil then target = not panel.Visible end
panel.Visible = target
if target then
panel.Position = PANEL_DEFAULT_POS
for _, entry in ipairs(sidePanels) do entry.frame.Visible = entry.isOpen end
task.wait(); repositionAllSidePanels()
reopenBtn.Visible = false
else
for _, entry in ipairs(sidePanels) do entry.frame.Visible = false end
reopenBtn.Visible = true
end
end

closeBtn.MouseButton1Click:Connect(function() togglePanel(false) end)
reopenBtn.MouseButton1Click:Connect(function() togglePanel(true) end)

