-- LIGHTING ENGINE
-- ============================================================
local function applyLighting(mode)
	local cc = Lighting:FindFirstChild("MainCC") or Instance.new("ColorCorrectionEffect", Lighting)
	cc.Name = "MainCC"; cc.Enabled = true
	local bloom = Lighting:FindFirstChild("URBloom") or Instance.new("BloomEffect", Lighting)
	bloom.Name = "URBloom"; bloom.Enabled = true

	vignette.Visible = false
	barLeft.Visible = false
	barRight.Visible = false
	chromaRed.Visible = false
	chromaBlue.Visible = false
	scanlines.Visible = false
	pressureTint.Visible = false

	if mode == "Normal" then
		Lighting.Technology = Enum.Technology.ShadowMap
		cc.TintColor = Color3.new(1,1,1)
		cc.Saturation = -0.1; cc.Contrast = 0.3
		bloom.Intensity = 0.4; bloom.Threshold = 0.9; bloom.Size = 8
		Lighting.ExposureCompensation = 0
		grain.ImageTransparency = 0.94
		grain.ImageRectOffset = Vector2.new(0, 0)

	elseif mode == "VHS" then
		Lighting.Technology = Enum.Technology.ShadowMap
		cc.Contrast = vhsSettings.contrast
		cc.Saturation = vhsSettings.saturation
		cc.TintColor = Color3.new(1,1,1)
		bloom.Intensity = 0.5; bloom.Threshold = 0.9; bloom.Size = 8
		Lighting.ExposureCompensation = vhsSettings.exposure
		grain.ImageTransparency = 0.78
		grain.ImageRectOffset = Vector2.new(128, 64)

	elseif mode == "analog" then
		Lighting.Technology = Enum.Technology.ShadowMap
		cc.TintColor = Color3.fromRGB(190, 210, 220)
		cc.Saturation = ahSettings.saturation
		cc.Contrast = ahSettings.contrast
		bloom.Intensity = ahSettings.bloom; bloom.Threshold = 0.3; bloom.Size = 30
		Lighting.ExposureCompensation = 0
		grain.ImageTransparency = 0.52
		grain.ImageRectOffset = Vector2.new(256, 192)
		vignette.Visible = true; vignette.ImageTransparency = 0.45
		barLeft.Visible = true; barRight.Visible = true
		chromaRed.Visible = true; chromaBlue.Visible = true
		scanlines.Visible = true

	elseif mode == "UR" then
		Lighting.Technology = Enum.Technology.ShadowMap
		cc.Contrast = 0.55; cc.Saturation = 0.15
		cc.TintColor = Color3.fromRGB(240, 245, 255)
		bloom.Intensity = 1.2; bloom.Size = 24; bloom.Threshold = 0.8
		Lighting.ExposureCompensation = 0
		grain.ImageTransparency = 0.94

	elseif mode == "untitled" then
		Lighting.Technology = Enum.Technology.ShadowMap
		cc.TintColor = Color3.fromRGB(255, 248, 235)
		cc.Saturation = 0.2; cc.Contrast = 0.5
		bloom.Intensity = 0.3; bloom.Threshold = 0.95; bloom.Size = 6
		Lighting.ExposureCompensation = 0.1
		grain.ImageTransparency = 1.0

	elseif mode == "pressure" then
		Lighting.Technology = Enum.Technology.ShadowMap
		cc.TintColor = Color3.fromRGB(160, 140, 220)
		cc.Saturation = -0.6; cc.Contrast = 0.6
		bloom.Intensity = 3.5; bloom.Threshold = 0.2; bloom.Size = 60
		Lighting.ExposureCompensation = -1.8
		grain.ImageTransparency = 0.65
		grain.ImageRectOffset = Vector2.new(64, 128)
		vignette.Visible = true; vignette.ImageTransparency = 0.15
		pressureTint.Visible = true
		scanlines.Visible = true

	elseif mode == "bw" then
		-- High contrast threshold â bright = pure white, dark = pure black
		Lighting.Technology = Enum.Technology.ShadowMap
		cc.TintColor = Color3.new(1, 1, 1)
		cc.Saturation = -1.0   -- fully desaturated
		cc.Contrast = 1.0      -- maximum contrast
		bloom.Intensity = 6.0  -- massive bloom so brights blow out to white
		bloom.Threshold = 0.1  -- catch everything bright
		bloom.Size = 80        -- wide spread so whites clip hard
		Lighting.ExposureCompensation = 0.8  -- push brights over the edge
		grain.ImageTransparency = 0.94

	elseif mode == "Reset" then
		Lighting.Technology = Enum.Technology.ShadowMap
		cc.Enabled = false; bloom.Enabled = false
		Lighting.ExposureCompensation = 0
		grain.ImageTransparency = 0.94
		grain.ImageRectOffset = Vector2.new(0, 0)
		motionBlur.Size = 0
	end
end

