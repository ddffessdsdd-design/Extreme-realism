-- ============================================================
-- RENDER LOOP
-- ============================================================
local prevCamCF        = camera.CFrame
local smoothFlCFrame   = CFrame.new()
local scanlineTimer    = 0

local function refreshScanlines()
	local vp=(camera and camera.ViewportSize) or Vector2.new(1280,720)
	local spacing=math.max(4,math.floor(vp.Y/#scanlineBars))
	local offset=math.floor((tick()*20)%spacing)
	for i,bar in ipairs(scanlineBars) do
		bar.Size=UDim2.new(1,0,0,1)
		bar.Position=UDim2.new(0,0,0,((i-1)*spacing+offset)%vp.Y)
	end
end

RunService.RenderStepped:Connect(function(dt)
	if not scriptEnabled then return end

	if effectGui.Enabled then
		scanlineTimer=scanlineTimer+dt
		if scanlineTimer>=.033 then scanlineTimer=0; refreshScanlines() end
		if chromaRed.Visible then
			local t=tick()
			chromaRed.Position=UDim2.new(0,math.sin(t*.7)*2,0,0)
			chromaBlue.Position=UDim2.new(0,math.cos(t*.5)*(-2),0,0)
		end
		-- Animated gloss pulse
		if glossSheen.Visible then
			local t=tick()
			glossSheen.BackgroundTransparency=.80+math.sin(t*1.5)*.08
		end
		-- Heat shimmer
		if heatTintOverlay.Visible then
			local t=tick()
			heatTintOverlay.BackgroundTransparency=.84+math.sin(t*3.0)*.04
		end
	end

	if motionBlurEnabled then
		local rp=character and character:FindFirstChild("HumanoidRootPart")
		if rp then
			local spd=Vector3.new(rp.AssemblyLinearVelocity.X,0,rp.AssemblyLinearVelocity.Z).Magnitude
			motionBlur.Size=spd>=mbSettings.speed and mbSettings.strength or 0
		end
	end

	if flashlightEnabled and camera then
		local tgt=camera.CFrame
		smoothFlCFrame=smoothFlCFrame:Lerp(tgt,1-flSettings.heaviness)
		lightPart.CFrame=smoothFlCFrame
	end

	if cameraShakeEnabled and cameraShakePreset~="Off" then
		local shake=getWalkShake(dt)
		camera.CFrame=camera.CFrame*shake
	end
	if viewBobbingEnabled then
		-- Simple sine bobbing
		local humanoid=character and character:FindFirstChildOfClass("Humanoid")
		local rp=character and character:FindFirstChild("HumanoidRootPart")
		if humanoid and rp then
			local spd=Vector3.new(rp.AssemblyLinearVelocity.X,0,rp.AssemblyLinearVelocity.Z).Magnitude
			if spd>0.5 then
				local t=tick()
				local amp=viewBobbingIntensity*.008
				local bob=CFrame.new(math.sin(t*6)*amp, math.abs(math.sin(t*9))*amp*1.5, 0)
				camera.CFrame=camera.CFrame*bob
			end
		end
	end
end)

