local function makeAdjuster(parent, label, order, getter, setter, minV, maxV, step)
	makeSectionLbl(parent, label, order)
	local row=Instance.new("Frame",parent)
	row.Size=UDim2.new(1,0,0,28); row.BackgroundTransparency=1; row.LayoutOrder=order+1
	local minus=Instance.new("TextButton",row)
	minus.Size=UDim2.new(0,26,0,24); minus.Position=UDim2.new(0,0,.5,-12)
	minus.BackgroundColor3=theme.bg2; minus.Text="-"; minus.TextColor3=theme.text
	minus.TextSize=13; minus.Font=Enum.Font.GothamBold; minus.BorderSizePixel=0; minus.AutoButtonColor=false
	createCorner(minus,6); local minSt=createStroke(minus,1,theme.accent); addShine(minus)
	local valLbl=Instance.new("TextLabel",row)
	valLbl.Size=UDim2.new(1,-108,1,0); valLbl.Position=UDim2.new(0,32,0,0)
	valLbl.BackgroundTransparency=1; valLbl.TextColor3=theme.muted; valLbl.TextSize=10
	valLbl.Font=Enum.Font.GothamSemibold; valLbl.Text=tostring(roundNumber(getter(),2))
	local plus=Instance.new("TextButton",row)
	plus.Size=UDim2.new(0,26,0,24); plus.Position=UDim2.new(1,-26,.5,-12)
	plus.BackgroundColor3=theme.bg2; plus.Text="+"; plus.TextColor3=theme.text
	plus.TextSize=13; plus.Font=Enum.Font.GothamBold; plus.BorderSizePixel=0; plus.AutoButtonColor=false
	createCorner(plus,6); local plSt=createStroke(plus,1,theme.accent); addShine(plus)
	local function refresh() valLbl.Text=tostring(roundNumber(getter(),2)) end
	minus.MouseButton1Click:Connect(function() setter(clamp(getter()-step,minV,maxV)); refresh() end)
	plus.MouseButton1Click:Connect(function()  setter(clamp(getter()+step,minV,maxV)); refresh() end)
	table.insert(refs.optionButtons,{btn=minus,stroke=minSt,active=false})
	table.insert(refs.optionButtons,{btn=plus,stroke=plSt,active=false})
	return {refresh=refresh,row=row}
end

