local function clamp(v, lo, hi) return math.max(lo, math.min(hi, v)) end
local function safeFindChild(p, n) return p:FindFirstChild(n) end
local function roundNumber(n, d) local p = 10^(d or 0); return math.floor(n*p+0.5)/p end

local function detectDeviceMode()
	if UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled then return "Phone" end
	if UserInputService.TouchEnabled and UserInputService.KeyboardEnabled then return "Tablet" end
	return "PC"
end

