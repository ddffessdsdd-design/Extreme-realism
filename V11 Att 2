-- ============================================================
-- GUI HIDE – sets ALL non-shader GUI transparency to 1
-- Covers: ScreenGui, SurfaceGui, GuiObjects, Highlights, UIStroke
-- Ignores: ShaderPanel, ShaderControl, ShaderOverlays, CoreGui is searched
--          but shader guis are skipped. CoreGui children are skipped entirely.
-- ============================================================
local hiddenSnapshots = {}

local function isShaderProtectedInstance(obj)
	if not obj then return false end
	return obj:IsDescendantOf(
		playerGui:FindFirstChild("ShaderPanel")    or game) == false and false
		or obj:FindFirstAncestorWhichIsA("ScreenGui") ~= nil and
		   (obj:FindFirstAncestorWhichIsA("ScreenGui").Name == "ShaderPanel"
		 or obj:FindFirstAncestorWhichIsA("ScreenGui").Name == "ShaderControl"
		 or obj:FindFirstAncestorWhichIsA("ScreenGui").Name == "ShaderOverlays")
end

local function isShaderGui(obj)
	-- Walk up to the ScreenGui root; skip if it belongs to us
	local cur = obj
	while cur and cur.Parent do
		if cur:IsA("ScreenGui") then
			local n = cur.Name
			return n=="ShaderPanel" or n=="ShaderControl" or n=="ShaderOverlays"
		end
		cur = cur.Parent
	end
	return false
end

toggleGuiVisibility = function(hide)
	-- We search playerGui, workspace (SurfaceGuis/Highlights there), and CoreGui
	local roots = { playerGui, workspace, CoreGui }

	if hide then
		for _, root in ipairs(roots) do
			if not root then continue end
			for _, obj in ipairs(root:GetDescendants()) do
				if isShaderGui(obj) then continue end
				if obj:IsA("ScreenGui") then
					hiddenSnapshots[obj] = hiddenSnapshots[obj] or { enabled=obj.Enabled }
					obj.Enabled = false
				elseif obj:IsA("SurfaceGui") then
					hiddenSnapshots[obj] = hiddenSnapshots[obj] or { enabled=obj.Enabled }
					obj.Enabled = false
				elseif obj:IsA("Highlight") then
					hiddenSnapshots[obj] = hiddenSnapshots[obj] or { fill=obj.FillTransparency, outline=obj.OutlineTransparency }
					obj.FillTransparency=1; obj.OutlineTransparency=1
				elseif obj:IsA("GuiObject") then
					hiddenSnapshots[obj] = hiddenSnapshots[obj] or {
						bg  = obj.BackgroundTransparency,
						txt = (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) and obj.TextTransparency or nil,
						img = (obj:IsA("ImageLabel") or obj:IsA("ImageButton")) and obj.ImageTransparency or nil,
					}
					obj.BackgroundTransparency = 1
					if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then obj.TextTransparency=1 end
					if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then obj.ImageTransparency=1 end
				elseif obj:IsA("UIStroke") then
					hiddenSnapshots[obj] = hiddenSnapshots[obj] or { thickness=obj.Thickness }
					obj.Thickness = 0
				end
			end
		end
	else
		for obj, data in pairs(hiddenSnapshots) do
			if obj and obj.Parent then
				if obj:IsA("UIStroke") then
					obj.Thickness = data.thickness or obj.Thickness
				elseif obj:IsA("ScreenGui") or obj:IsA("SurfaceGui") then
					obj.Enabled = data.enabled ~= false
				elseif obj:IsA("Highlight") then
					obj.FillTransparency   = data.fill    or obj.FillTransparency
					obj.OutlineTransparency= data.outline or obj.OutlineTransparency
				else
					obj.BackgroundTransparency = data.bg or obj.BackgroundTransparency
					if data.txt ~= nil then obj.TextTransparency=data.txt end
					if data.img ~= nil then obj.ImageTransparency=data.img end
				end
			end
		end
		hiddenSnapshots = {}
	end
end

-- ============================================================
-- WALK SHAKE
-- ============================================================
local shakeTime = 0
local function getWalkShake(dt)
	if not cameraShakeEnabled or cameraShakePreset == "Off" then return CFrame.new() end
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	if not humanoid or not rootPart then return CFrame.new() end
	local vel   = rootPart.AssemblyLinearVelocity
	local speed = Vector3.new(vel.X,0,vel.Z).Magnitude
	local moving = speed>.8 and humanoid.FloorMaterial~=Enum.Material.Air
	if not moving then shakeTime=shakeTime+dt*2; return CFrame.new() end
	shakeTime = shakeTime + dt*(8+speed*.15)
	local baseAmp = shakePresets[cameraShakePreset] or 0
	local amp = baseAmp * clamp(speed/16,.55,1.35)
	return CFrame.new(math.sin(shakeTime*7)*amp, -math.abs(math.sin(shakeTime*11))*amp*.65, math.sin(shakeTime*4.5)*amp*.45)
		* CFrame.Angles(0,0, math.sin(shakeTime*5.5)*math.rad(.35+amp*80))
end

