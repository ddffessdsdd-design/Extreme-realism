local function setOverlayVisibility(name, v)
	if name == "vignette" then
		vignetteTop.Visible=v; vignetteBottom.Visible=v; vignetteLeft.Visible=v; vignetteRight.Visible=v
	elseif name == "pressure"       then pressureTint.Visible=v
	elseif name == "bwGlow"         then bwGlow.Visible=v
	elseif name == "chroma"         then chromaRed.Visible=v; chromaBlue.Visible=v
	elseif name == "glossSheen"     then glossSheen.Visible=v
	elseif name == "warmTint"       then warmTintOverlay.Visible=v
	elseif name == "frostedOverlay" then frostedOverlay.Visible=v
	elseif name == "heatTint"       then heatTintOverlay.Visible=v
	elseif name == "bars" or name == "scanlines" then
		for _, bar in ipairs(scanlineBars) do bar.Visible=v end
	end
end

