local function getEffects()
	local cc    = safeFindChild(Lighting,"MainCC")    or Instance.new("ColorCorrectionEffect",Lighting)
	cc.Name     = "MainCC"
	local bloom = safeFindChild(Lighting,"MainBloom") or Instance.new("BloomEffect",Lighting)
	bloom.Name  = "MainBloom"
	return cc, bloom
end

local function applyFlSettings()
	fl.Brightness = flSettings.brightness; fl.Range = flSettings.range
	if flSettings.blendColors then
		local a = Lighting.Ambient
		fl.Color = Color3.new((flSettings.color.R+a.R)/2,(flSettings.color.G+a.G)/2,(flSettings.color.B+a.B)/2)
	else fl.Color = flSettings.color end
end

local function applyMode(mode)
	local cc, bloom = getEffects()
	local cfg = modeConfigs[mode] or modeConfigs.Normal

	currentMode        = mode
	effectGui.Enabled  = mode ~= "Normal"
	hideAllOverlays()
	Lighting.Technology = Enum.Technology.ShadowMap
	cc.Enabled = true; bloom.Enabled = true

	local sat = cfg.saturation; local con = cfg.contrast
	local bri = cfg.brightness; local exp = cfg.exposure
	local bi  = cfg.bloomIntensity; local bt = cfg.bloomThreshold; local bs = cfg.bloomSize

	if mode == "VHS" then
		sat = vhsSettings.saturation; con = vhsSettings.contrast; exp = vhsSettings.exposure
	elseif mode == "analog" then
		sat = ahSettings.saturation; con = ahSettings.contrast; bi = ahSettings.bloom
	elseif mode == "pressure" then
		pressureTint.Visible = true
		pressureTint.BackgroundColor3 = Color3.fromRGB(55,10,10)
		pressureTint.BackgroundTransparency = .75-(pressureIntensity*.06)
		cc.TintColor = Color3.fromRGB(140,35,35)
		cc.Saturation=-.75; cc.Contrast=.62+(pressureIntensity*.10)
		cc.Brightness=-.20-(pressureIntensity*.07)
		Lighting.ExposureCompensation=-.90-(pressureIntensity*.12)
		bloom.Intensity=.85+(pressureIntensity*.15)
		return
	elseif mode == "bw" then
		bwGlow.Visible=true
		bwGlow.BackgroundTransparency=.95-(bwBrightness*.02)
		cc.TintColor=Color3.fromRGB(255,255,255)
		cc.Saturation=-1; cc.Contrast=.95+bwContrast
		cc.Brightness=.18+bwBrightness
		Lighting.ExposureCompensation=.12; bloom.Intensity=.10
		return
	end

	cc.TintColor = cfg.tint
	cc.Saturation           = clamp(sat+customAdjust.saturation, -1, 1)
	cc.Contrast             = clamp(con+customAdjust.contrast,   -1, 1)
	cc.Brightness           = clamp(bri+customAdjust.brightness, -1, 1)
	Lighting.ExposureCompensation = clamp(exp+customAdjust.exposure, -5, 5)
	bloom.Intensity         = math.max(0, bi+customAdjust.bloom)
	bloom.Threshold         = clamp(bt, 0, 1)
	bloom.Size              = math.max(0, bs)

	for name, vis in pairs(cfg.overlays or {}) do setOverlayVisibility(name, vis) end

	if mode == "Normal" then
		effectGui.Enabled=false; cc.Enabled=false; bloom.Enabled=false
		Lighting.ExposureCompensation=0; hideAllOverlays()
	end

	-- update enable flags
	vhsEnabled=(mode=="VHS"); analogEnabled=(mode=="analog"); urEnabled=(mode=="UR")
	untitledEnabled=(mode=="untitled"); pressureEnabled=(mode=="pressure"); bwEnabled=(mode=="bw")
	crtEnabled=(mode=="crt"); nightVisionEnabled=(mode=="nightVision"); thermalEnabled=(mode=="thermal")
	foundFootageEnabled=(mode=="foundFootage"); glossyEnabled=(mode=="glossy")
