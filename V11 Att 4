	for _, child in ipairs(profileListFrame:GetChildren()) do
		if child:IsA("TextButton") then child:Destroy() end
	end

	local names = {}
	for k in pairs(savedProfiles) do table.insert(names, k) end
	table.sort(names)

	if #names == 0 then
		profileListFrame.Size = UDim2.new(1, 0, 0, 4)
		return
	end

	for i, name in ipairs(names) do
		local entryRow = Instance.new("Frame")
		entryRow.Parent = profileListFrame
