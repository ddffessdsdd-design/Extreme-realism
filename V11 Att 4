	if refs.titleLabel then refs.titleLabel.TextSize = sz.titleSize end
	if refs.statusTitle then refs.statusTitle.TextSize = sz.statusSize end
	if refs.statusLabel then refs.statusLabel.TextSize = sz.statusSize + 1 end
	if refs.reopenBtn then
		refs.reopenBtn.Size = UDim2.new(0, resolvedUiMode=="PC" and 38 or 34, 0, resolvedUiMode=="PC" and 38 or 34)
