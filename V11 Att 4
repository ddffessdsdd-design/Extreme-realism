updateStatus = function()
	local parts = {}
	if currentMode ~= "Normal" then table.insert(parts, "◆ "..currentMode:upper()) end
	if flashlightEnabled  then table.insert(parts, "◆ FL") end
	if motionBlurEnabled  then table.insert(parts, "◆ MB") end
	if colorTintEnabled   then table.insert(parts, "◆ TINT") end
	if audioEchoEnabled or audioReverbEnabled or audioPitchEnabled then
		table.insert(parts, "◆ AUDIO") end
	if viewBobbingEnabled then table.insert(parts, "◆ BOB") end
	if guiHidden          then table.insert(parts, "◆ UI HIDDEN") end
	if not scriptEnabled  then table.insert(parts, "◆ DISABLED") end
	refs.statusLabel.Text = (#parts > 0) and table.concat(parts, "  ") or "None"

	if autoSaveReady and profileDirty and not isLoadingProfile then
		saveProfile(autoProfileName)
		profileDirty = false
	end
end

