-- HIDE UI FUNCTION (sets all non-shader GUIs to transparent)
-- ============================================================
local hiddenSnapshots = {}

local function isShaderProtectedInstance(obj)
	if not obj then return false end
	return obj:IsDescendantOf(mainGui)
		or obj:IsDescendantOf(controlGui)
		or obj:IsDescendantOf(effectGui)
end

local toggleGuiVisibility
toggleGuiVisibility = function(hide)
	local roots = { playerGui, workspace, CoreGui }

	if hide then
		for _, root in ipairs(roots) do
			if root then
				for _, obj in ipairs(root:GetDescendants()) do
					if isShaderProtectedInstance(obj) then continue end

					if obj:IsA("ScreenGui") then
						hiddenSnapshots[obj] = hiddenSnapshots[obj] or { enabled=obj.Enabled }
						obj.Enabled = false
					elseif obj:IsA("SurfaceGui") then
						hiddenSnapshots[obj] = hiddenSnapshots[obj] or { enabled=obj.Enabled }
						obj.Enabled = false
					elseif obj:IsA("BillboardGui") then
						hiddenSnapshots[obj] = hiddenSnapshots[obj] or { enabled=obj.Enabled }
						obj.Enabled = false
					elseif obj:IsA("GuiObject") then
						hiddenSnapshots[obj] = hiddenSnapshots[obj] or {
							bg  = obj.BackgroundTransparency,
							txt = (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) and obj.TextTransparency or nil,
							img = (obj:IsA("ImageLabel") or obj:IsA("ImageButton")) and obj.ImageTransparency or nil,
						}
						obj.BackgroundTransparency = 1
						if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
							obj.TextTransparency = 1
						end
						if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
							obj.ImageTransparency = 1
						end
					elseif obj:IsA("UIStroke") then
						hiddenSnapshots[obj] = hiddenSnapshots[obj] or { thickness=obj.Thickness }
						obj.Thickness = 0
					elseif obj:IsA("Highlight") then
						hiddenSnapshots[obj] = hiddenSnapshots[obj] or {
							fill=obj.FillTransparency,
							outline=obj.OutlineTransparency,
						}
						obj.FillTransparency = 1
						obj.OutlineTransparency = 1
					end
				end
			end
		end
	else
		for obj, data in pairs(hiddenSnapshots) do
			if obj and obj.Parent then
				if obj:IsA("UIStroke") then
					obj.Thickness = data.thickness or obj.Thickness
				elseif obj:IsA("ScreenGui") or obj:IsA("SurfaceGui") or obj:IsA("BillboardGui") then
					obj.Enabled = data.enabled ~= false
				elseif obj:IsA("Highlight") then
					obj.FillTransparency    = data.fill    or obj.FillTransparency
					obj.OutlineTransparency = data.outline or obj.OutlineTransparency
				else
					obj.BackgroundTransparency = data.bg or obj.BackgroundTransparency
					if data.txt ~= nil then obj.TextTransparency = data.txt end
					if data.img ~= nil then obj.ImageTransparency = data.img end
				end
			end
		end
		hiddenSnapshots = {}
	end
end

