local function sanitizeProfileName(name)
	name = tostring(name or ""):gsub("^%s+",""):gsub("%s+$","")
	name = name:gsub("[^%w%-%_ ]","_")
	if name == "" then name = autoProfileName end
	return name
end

local function buildProfileData()
	return {
		version = 2,
		currentMode = currentMode,
		scriptEnabled = scriptEnabled,
		guiHidden = guiHidden,
		uiModeSetting = uiModeSetting,
		themeName = themeName,
		gradientName = gradientName,
		cameraShakePreset = cameraShakePreset,
		cameraShakeEnabled = cameraShakeEnabled,
		viewBobbingEnabled = viewBobbingEnabled,
		viewBobbingIntensity = viewBobbingIntensity,
		viewBobbingSpeed = viewBobbingSpeed,
		bwBrightness = bwBrightness,
		bwContrast = bwContrast,
		pressureIntensity = pressureIntensity,
		glossyIntensity = glossyIntensity,
		flashlightEnabled = flashlightEnabled,
		motionBlurEnabled = motionBlurEnabled,
		colorTintEnabled = colorTintEnabled,
		colorTintHue = colorTintHue,
		colorTintSaturation = colorTintSaturation,
		colorTintBrightness = colorTintBrightness,
		audioEchoEnabled = audioEchoEnabled,
		audioReverbEnabled = audioReverbEnabled,
		audioPitchEnabled = audioPitchEnabled,
		audioPitchValue = audioPitchValue,
		audioEchoDelay = audioEchoDelay,
		audioEchoFeedback = audioEchoFeedback,
		flSettings = {
			brightness = flSettings.brightness,
			heaviness  = flSettings.heaviness,
			color = { R=flSettings.color.R, G=flSettings.color.G, B=flSettings.color.B },
			blendColors = flSettings.blendColors,
			range = flSettings.range,
		},
		mbSettings  = { strength=mbSettings.strength, speed=mbSettings.speed },
		vhsSettings = { contrast=vhsSettings.contrast, saturation=vhsSettings.saturation, exposure=vhsSettings.exposure },
