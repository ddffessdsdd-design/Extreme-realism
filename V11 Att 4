-- ============================================================
-- RENDER LOOP
-- ============================================================
local prevCamCF       = camera.CFrame
local smoothFlCFrame  = CFrame.new()
local scanlineTimer   = 0
local acidTimer       = 0
local dreamTimer      = 0
local waterTimer      = 0

local function refreshScanlines()
	local viewport = (camera and camera.ViewportSize) or Vector2.new(1280, 720)
	local spacing = math.max(4, math.floor(viewport.Y / #scanlineBars))
	local offset = math.floor((tick() * 20) % spacing)
	for i, bar in ipairs(scanlineBars) do
		bar.Size = UDim2.new(1, 0, 0, 1)
		bar.Position = UDim2.new(0, 0, 0, ((i-1) * spacing + offset) % viewport.Y)
	end
end

RunService.RenderStepped:Connect(function(dt)
	if not camera then
		camera = workspace.CurrentCamera
		if not camera then return end
	end

	-- Camera shake & view bob
	if scriptEnabled and (cameraShakeEnabled or viewBobbingEnabled) then
		camera.CFrame = camera.CFrame * getWalkShake(dt)
	end

	-- Motion blur
	if motionBlurEnabled then
		local diff = math.deg(math.acos(clamp(prevCamCF.LookVector:Dot(camera.CFrame.LookVector), -1, 1)))
		local trigger = mbSettings.speed
		local ratio = clamp((diff - trigger) / trigger, 0, 1)
		motionBlur.Size = motionBlur.Size + (ratio * mbSettings.strength - motionBlur.Size) * 0.25
	else
		motionBlur.Size = 0
	end

	prevCamCF = camera.CFrame

	-- Flashlight follow
	if flashlightEnabled then
		local lerpSpeed = clamp((1 - flSettings.heaviness) * 14, 0.5, 14)
		smoothFlCFrame = smoothFlCFrame:Lerp(camera.CFrame, dt * lerpSpeed)
		lightPart.CFrame = smoothFlCFrame
	end

	if effectGui.Enabled then
		-- Scanlines animation
		if currentMode == "VHS" or currentMode == "analog" or currentMode == "crt"
			or currentMode == "foundFootage" or currentMode == "nightVision" then
			scanlineTimer = scanlineTimer + dt
			if scanlineTimer >= 0.10 then
				scanlineTimer = 0
				refreshScanlines()
			end
		end

		-- Chroma drift
		if currentMode == "analog" or currentMode == "crt" then
			local drift = math.sin(tick() * 2) * 1.5
			chromaRed.Position  = UDim2.new(0, -2 + drift, 0, 0)
			chromaBlue.Position = UDim2.new(0, 2 - drift,  0, 0)
		end

		-- B&W glow pulse
		if currentMode == "bw" then
			bwGlow.BackgroundTransparency = 0.94 + math.sin(tick() * 2) * 0.01
		end

		-- Pressure tint pulse
		if currentMode == "pressure" then
			local intens = pressureIntensity
			pressureTint.BackgroundTransparency = (0.75 - intens*0.06) + math.sin(tick() * 1.5) * 0.02
		end

		-- Glossy shimmer
		if currentMode == "glossy" then
			glossyGrad.Rotation = (math.floor(tick() * 20) % 360)
			glossyShine.BackgroundTransparency = 0.80 + math.sin(tick() * 1.8) * 0.05
		end

		-- Retro grain flicker
		if currentMode == "retro" then
			retroGrain.BackgroundTransparency = 0.88 + math.sin(tick() * 40) * 0.06
		end

		-- Acid pulse
		if currentMode == "acid" then
			acidTimer = acidTimer + dt
			local h = (acidTimer * 0.5) % 1
			acidPulse.BackgroundColor3 = hsvToColor3(h, 0.8, 0.6)
			acidPulse.BackgroundTransparency = 0.90 + math.sin(tick() * 6) * 0.05
		end

		-- Dream bloom drift
		if currentMode == "dream" then
			dreamTimer = dreamTimer + dt
			local dh = (dreamTimer * 0.2) % 1
			dreamBloom.BackgroundColor3 = hsvToColor3(dh, 0.3, 0.8)
			dreamBloom.BackgroundTransparency = 0.88 + math.sin(tick() * 0.8) * 0.03
		end

		-- Horror red pulse
		if currentMode == "horror" then
			horrorTint.BackgroundTransparency = 0.82 + math.sin(tick() * 2.5) * 0.06
		end

		-- Water distort shimmer
		if currentMode == "underwater" then
			waterTimer = waterTimer + dt
			waterOverlay.BackgroundTransparency = 0.91 + math.sin(waterTimer * 3) * 0.04
			local cc2 = safeFindChild(Lighting,"MainCC")
			if cc2 then
				cc2.Saturation = 0.10 + math.sin(waterTimer * 1.5) * 0.02
			end
		end
	end
end)

