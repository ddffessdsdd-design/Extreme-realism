local function saveProfile(profileName)
	profileName = sanitizeProfileName(profileName)
	local json = HttpService:JSONEncode(buildProfileData())
	if type(writefile)=="function" and type(isfolder)=="function" and type(makefolder)=="function" then
		pcall(function()
			if not isfolder(profileStorageFolder) then makefolder(profileStorageFolder) end
			writefile(profileStorageFolder.."/"..profileName..".json", json)
		end)
	end
	savedProfiles[profileName] = json
	profileStatusLbl.Text = "Saved: "..profileName
	refreshProfileList()
end

loadProfile = function(profileName)
	profileName = sanitizeProfileName(profileName)
	local json

	if type(readfile)=="function" and type(isfile)=="function" then
		local ok, result = pcall(function()
			if isfile(profileStorageFolder.."/"..profileName..".json") then
				return readfile(profileStorageFolder.."/"..profileName..".json")
			end
		end)
		if ok then json = result end
	end

	if not json and savedProfiles[profileName] then
		json = savedProfiles[profileName]
	end

	if not json then
		profileStatusLbl.Text = "Not found: "..profileName
		return false
	end

	local ok, data = pcall(function() return HttpService:JSONDecode(json) end)
	if not ok or type(data) ~= "table" then
		profileStatusLbl.Text = "Error loading: "..profileName
		return false
	end

	isLoadingProfile = true

	currentMode           = data.currentMode or "Normal"
	scriptEnabled         = data.scriptEnabled ~= false
	guiHidden             = data.guiHidden == true
	uiModeSetting         = data.uiModeSetting or uiModeSetting
	themeName             = data.themeName or themeName
	gradientName          = data.gradientName or gradientName
	cameraShakePreset     = data.cameraShakePreset or cameraShakePreset
	cameraShakeEnabled    = data.cameraShakeEnabled == true
	viewBobbingEnabled    = data.viewBobbingEnabled == true
	viewBobbingIntensity  = tonumber(data.viewBobbingIntensity) or viewBobbingIntensity
	viewBobbingSpeed      = tonumber(data.viewBobbingSpeed) or viewBobbingSpeed
	bwBrightness          = tonumber(data.bwBrightness) or bwBrightness
	bwContrast            = tonumber(data.bwContrast) or bwContrast
	pressureIntensity     = tonumber(data.pressureIntensity) or pressureIntensity
	glossyIntensity       = tonumber(data.glossyIntensity) or glossyIntensity
	flashlightEnabled     = data.flashlightEnabled == true
	motionBlurEnabled     = data.motionBlurEnabled == true
	colorTintEnabled      = data.colorTintEnabled == true
	colorTintHue          = tonumber(data.colorTintHue) or colorTintHue
	colorTintSaturation   = tonumber(data.colorTintSaturation) or colorTintSaturation
	colorTintBrightness   = tonumber(data.colorTintBrightness) or colorTintBrightness
	audioEchoEnabled      = data.audioEchoEnabled == true
	audioReverbEnabled    = data.audioReverbEnabled == true
	audioPitchEnabled     = data.audioPitchEnabled == true
	audioPitchValue       = tonumber(data.audioPitchValue) or audioPitchValue
	audioEchoDelay        = tonumber(data.audioEchoDelay) or audioEchoDelay
	audioEchoFeedback     = tonumber(data.audioEchoFeedback) or audioEchoFeedback

	if type(data.customAdjust) == "table" then
		customAdjust.saturation = tonumber(data.customAdjust.saturation) or customAdjust.saturation
		customAdjust.contrast   = tonumber(data.customAdjust.contrast)   or customAdjust.contrast
		customAdjust.brightness = tonumber(data.customAdjust.brightness) or customAdjust.brightness
		customAdjust.bloom      = tonumber(data.customAdjust.bloom)      or customAdjust.bloom
		customAdjust.exposure   = tonumber(data.customAdjust.exposure)   or customAdjust.exposure
	end

	if type(data.flSettings) == "table" then
		flSettings.brightness  = tonumber(data.flSettings.brightness) or flSettings.brightness
		flSettings.heaviness   = tonumber(data.flSettings.heaviness) or flSettings.heaviness
		flSettings.range       = tonumber(data.flSettings.range) or flSettings.range
		flSettings.blendColors = data.flSettings.blendColors == true
		if type(data.flSettings.color) == "table" then
			local r = clamp(tonumber(data.flSettings.color.R) or 1, 0, 1)
			local g = clamp(tonumber(data.flSettings.color.G) or 1, 0, 1)
			local b = clamp(tonumber(data.flSettings.color.B) or 1, 0, 1)
			flSettings.color = Color3.new(r, g, b)
		end
	end

	if type(data.mbSettings)  == "table" then
		mbSettings.strength = tonumber(data.mbSettings.strength) or mbSettings.strength
		mbSettings.speed    = tonumber(data.mbSettings.speed) or mbSettings.speed
	end
	if type(data.vhsSettings) == "table" then
		vhsSettings.contrast   = tonumber(data.vhsSettings.contrast) or vhsSettings.contrast
		vhsSettings.saturation = tonumber(data.vhsSettings.saturation) or vhsSettings.saturation
		vhsSettings.exposure   = tonumber(data.vhsSettings.exposure) or vhsSettings.exposure
	end
	if type(data.ahSettings)  == "table" then
		ahSettings.contrast   = tonumber(data.ahSettings.contrast) or ahSettings.contrast
		ahSettings.saturation = tonumber(data.ahSettings.saturation) or ahSettings.saturation
		ahSettings.bloom      = tonumber(data.ahSettings.bloom) or ahSettings.bloom
	end

	applyUiMode()
	applyTheme()
	refreshSidePanelSizes()
	applyFlSettings()
	applyMode(currentMode)
	applyAudioFX()
	refreshEffectButtons()

	fl.Enabled = flashlightEnabled
	if not motionBlurEnabled then motionBlur.Size = 0 end

	setMainPanelVisible(true)
	if guiHidden then toggleGuiVisibility(true) end

	setModeButtonState(btnHideUI,  guiHidden,          "HIDE UI",        "HIDE UI")
	setModeButtonState(btnToggle,  scriptEnabled,      "ENABLED",        "DISABLED")
	setModeButtonState(btnFL,      flashlightEnabled,  "FLASHLIGHT ⬡",  "FLASHLIGHT ⬡")
	setModeButtonState(btnMB,      motionBlurEnabled,  "MOTION BLUR ⬡", "MOTION BLUR ⬡")
	setModeButtonState(btnColorTint,colorTintEnabled,  "COLOR TINT ⬡",  "COLOR TINT ⬡")
	setModeButtonState(btnAudio,   (audioEchoEnabled or audioReverbEnabled or audioPitchEnabled), "AUDIO FX ⬡", "AUDIO FX ⬡")

	viewBobbingToggle.active = viewBobbingEnabled
	viewBobbingToggle.btn.Text = viewBobbingEnabled and "View Bobbing: ON" or "View Bobbing: OFF"
	setOptButtonState(viewBobbingToggle, viewBobbingEnabled)

	colorTintToggle.active = colorTintEnabled
	colorTintToggle.btn.Text = colorTintEnabled and "Color Tint: ON" or "Color Tint: OFF"
	setOptButtonState(colorTintToggle, colorTintEnabled)

	audioReverbToggle.active = audioReverbEnabled
	audioReverbToggle.btn.Text = audioReverbEnabled and "Reverb: ON" or "Reverb: OFF"
	setOptButtonState(audioReverbToggle, audioReverbEnabled)

	audioEchoToggle.active = audioEchoEnabled
	audioEchoToggle.btn.Text = audioEchoEnabled and "Echo EQ: ON" or "Echo EQ: OFF"
	setOptButtonState(audioEchoToggle, audioEchoEnabled)

	audioPitchToggle.active = audioPitchEnabled
	audioPitchToggle.btn.Text = audioPitchEnabled and "Pitch Shift: ON" or "Pitch Shift: OFF"
	setOptButtonState(audioPitchToggle, audioPitchEnabled)

	blendMeta.active = flSettings.blendColors
	blendMeta.btn.Text = flSettings.blendColors and "Blend Colors: ON" or "Blend Colors: OFF"
	setOptButtonState(blendMeta, blendMeta.active)

	updateStatus()
	isLoadingProfile = false
	profileDirty = false
	profileStatusLbl.Text = "Loaded: "..profileName
	return true
end

