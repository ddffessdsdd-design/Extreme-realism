local function tryLoadAutosave()
	autoSaveReady = false
	-- also scan filesystem for existing profiles
	if type(listfiles) == "function" and type(isfolder) == "function" then
		pcall(function()
			if isfolder(profileStorageFolder) then
				local files = listfiles(profileStorageFolder)
				for _, path in ipairs(files) do
					local name = path:match("([^/\\]+)%.json$")
					if name then
						local ok, content = pcall(readfile, path)
						if ok and content then
							savedProfiles[name] = content
						end
					end
				end
			end
		end)
	end
	refreshProfileList()
	if savedProfiles[autoProfileName] then
		loadProfile(autoProfileName)
	end
	autoSaveReady = true
	profileDirty = false
end

