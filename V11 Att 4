local function getEffects()
	local cc = safeFindChild(Lighting, "MainCC")
	if not cc then
		cc = Instance.new("ColorCorrectionEffect")
		cc.Name = "MainCC"
		cc.Parent = Lighting
	end
	local bloom = safeFindChild(Lighting, "MainBloom")
	if not bloom then
		bloom = Instance.new("BloomEffect")
		bloom.Name = "MainBloom"
		bloom.Parent = Lighting
	end
	return cc, bloom
end

local function applyFlSettings()
	fl.Brightness = flSettings.brightness
	fl.Range = flSettings.range
	if flSettings.blendColors then
		local a = Lighting.Ambient
		fl.Color = Color3.new(
			(flSettings.color.R + a.R) / 2,
			(flSettings.color.G + a.G) / 2,
			(flSettings.color.B + a.B) / 2
		)
	else
		fl.Color = flSettings.color
	end
end

local savedAmbient = Lighting.Ambient
local savedOutdoorAmbient = Lighting.OutdoorAmbient

local function applyColorTint()
	if not colorTintEnabled then
		Lighting.Ambient = savedAmbient
		Lighting.OutdoorAmbient = savedOutdoorAmbient
		return
	end
	local col = hsvToColor3(colorTintHue, colorTintSaturation, colorTintBrightness)
	local tintedAmbient = Color3.new(
		clamp(col.R * 0.5, 0, 1),
		clamp(col.G * 0.5, 0, 1),
		clamp(col.B * 0.5, 0, 1)
	)
	Lighting.Ambient = tintedAmbient
	Lighting.OutdoorAmbient = Color3.new(
		clamp(col.R * 0.7, 0, 1),
		clamp(col.G * 0.7, 0, 1),
		clamp(col.B * 0.7, 0, 1)
	)
end

-- Audio FX (applied to SoundService DistortionSoundEffect / ReverbSoundEffect)
local echoEffect = nil
local reverbEffect = nil
local pitchEffect = nil

local function getOrMakeSoundEffect(className, name)
	local existing = SoundService:FindFirstChild(name)
	if existing then return existing end
	local eff = Instance.new(className)
	eff.Name = name
	eff.Parent = SoundService
	return eff
end

local function applyAudioFX()
	-- Echo
	if audioEchoEnabled then
		if not echoEffect then
			echoEffect = getOrMakeSoundEffect("EqualizerSoundEffect", "ShaderEcho")
		end
		echoEffect.Parent = SoundService
		echoEffect.LowGain = -5
		echoEffect.MidGain = 0
		echoEffect.HighGain = -8
	else
		if echoEffect then echoEffect.Parent = nil end
	end

	-- Reverb
	if audioReverbEnabled then
		if not reverbEffect then
			reverbEffect = getOrMakeSoundEffect("ReverbSoundEffect", "ShaderReverb")
		end
		reverbEffect.Parent = SoundService
		reverbEffect.DecayTime = clamp(audioEchoDelay * 6, 0.1, 30)
		reverbEffect.Density = clamp(audioEchoFeedback, 0, 1)
		reverbEffect.Diffusion = 0.8
		reverbEffect.DryLevel = 0
		reverbEffect.WetLevel = -6
	else
		if reverbEffect then reverbEffect.Parent = nil end
	end

	-- Pitch
	if audioPitchEnabled then
		if not pitchEffect then
			pitchEffect = getOrMakeSoundEffect("PitchShiftSoundEffect", "ShaderPitch")
		end
		pitchEffect.Parent = SoundService
		pitchEffect.Octave = clamp(audioPitchValue, 0.5, 2.0)
	else
		if pitchEffect then pitchEffect.Parent = nil end
	end
end

local function applyMode(mode)
	local cc, bloom = getEffects()
	local cfg = modeConfigs[mode] or modeConfigs.Normal
	currentMode = mode
	effectGui.Enabled = (mode ~= "Normal")
	hideAllOverlays()

	local sat = cfg.saturation + customAdjust.saturation
	local con = cfg.contrast + customAdjust.contrast
	local bri = cfg.brightness + customAdjust.brightness
	local exp = cfg.exposure + customAdjust.exposure
	local blo = cfg.bloomIntensity + customAdjust.bloom

	cc.Saturation = sat
	cc.Contrast = con
	cc.Brightness = bri
	cc.TintColor = cfg.tint
	Lighting.ExposureCompensation = exp
	bloom.Intensity = math.max(0, blo)
	bloom.Threshold = cfg.bloomThreshold
	bloom.Size = cfg.bloomSize

	for name, vis in pairs(cfg.overlays) do
		if vis then setOverlayVisibility(name, true) end
	end

	-- Glossy extra
	if mode == "glossy" then
		glossyShine.BackgroundTransparency = 1 - (glossyIntensity * 0.25)
	end

	applyColorTint()
end

