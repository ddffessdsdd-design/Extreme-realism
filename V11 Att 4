local function setOverlayVisibility(name, visible)
	if name == "vignette" then
		vignetteTop.Visible=visible; vignetteBot.Visible=visible
		vignetteLeft.Visible=visible; vignetteRight.Visible=visible
	elseif name == "pressure" then pressureTint.Visible=visible
	elseif name == "bwGlow"   then bwGlow.Visible=visible
	elseif name == "chroma"   then chromaRed.Visible=visible; chromaBlue.Visible=visible
	elseif name == "bars"     then
		for _, bar in ipairs(scanlineBars) do bar.Visible=visible end
	elseif name == "scanlines" then
		for _, bar in ipairs(scanlineBars) do bar.Visible=visible end
	elseif name == "glossyShine" then glossyShine.Visible=visible
	elseif name == "retro"    then retroGrain.Visible=visible
	elseif name == "acidPulse" then acidPulse.Visible=visible
	elseif name == "dreamBloom" then dreamBloom.Visible=visible
	elseif name == "horror"   then horrorTint.Visible=visible
	elseif name == "cineBars" then cineTop.Visible=visible; cineBot.Visible=visible
	elseif name == "waterDistort" then waterOverlay.Visible=visible
	end
end

local function hideAllOverlays()
	vignetteTop.Visible=false; vignetteBot.Visible=false
	vignetteLeft.Visible=false; vignetteRight.Visible=false
	pressureTint.Visible=false; bwGlow.Visible=false
	chromaRed.Visible=false; chromaBlue.Visible=false
	glossyShine.Visible=false; retroGrain.Visible=false
	acidPulse.Visible=false; dreamBloom.Visible=false
	horrorTint.Visible=false; cineTop.Visible=false; cineBot.Visible=false
	waterOverlay.Visible=false
	for _, bar in ipairs(scanlineBars) do bar.Visible=false end
end

