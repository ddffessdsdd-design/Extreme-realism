local function toggleMode(mode, meta, sidePanelEntry)
	if not scriptEnabled then return end
	if currentMode == mode then
		closeAllSidePanels()
		applyMode("Normal")
		setModeButtonVisual(meta, false)
	else
		closeAllSidePanels()
		applyMode(mode)
		refreshEffectButtons()
		if sidePanelEntry then openSidePanel(sidePanelEntry) end
	end
	updateStatus()
	profileDirty = true
end

