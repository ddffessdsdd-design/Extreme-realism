-- LIGHTING ENGINE
local function applyLighting(mode)
	local cc = Lighting:FindFirstChild("MainCC") or Instance.new("ColorCorrectionEffect", Lighting)
	cc.Name = "MainCC"; cc.Enabled = true
	local bloom = Lighting:FindFirstChild("URBloom") or Instance.new("BloomEffect", Lighting)
	bloom.Name = "URBloom"; bloom.Enabled = true

	vignette.Visible = false
	barLeft.Visible = false
	barRight.Visible = false
	chromaRed.Visible = false
	chromaBlue.Visible = false
	scanlines.Visible = false

	if mode == "Normal" then
		Lighting.Technology = Enum.Technology.ShadowMap
		cc.TintColor = Color3.new(1, 1, 1)
		cc.Saturation = -0.1
		cc.Contrast = 0.3
		bloom.Intensity = 0.4
		bloom.Threshold = 0.9
		bloom.Size = 8
		Lighting.ExposureCompensation = 0
		grain.ImageTransparency = 0.94

	elseif mode == "analog" then
		-- Old recording look: washed out, low contrast, teal tint,
		-- heavy grain, scanlines, chromatic fringing on lights
		-- ExposureCompensation = 0 so it never goes black
		Lighting.Technology = Enum.Technology.ShadowMap
		cc.TintColor = Color3.fromRGB(170, 210, 220) -- muted teal, not too blue
		cc.Saturation = -0.4   -- partial desaturation, some color shows
		cc.Contrast = -0.1     -- NEGATIVE contrast = washed out/low quality look
		bloom.Intensity = 1.8
		bloom.Threshold = 0.25
		bloom.Size = 40
		Lighting.ExposureCompensation = 0
		grain.ImageTransparency = 0.55  -- heavy grain = old recording
		vignette.Visible = true
		barLeft.Visible = true
		barRight.Visible = true
		chromaRed.Visible = true
		chromaBlue.Visible = true
		scanlines.Visible = true

	elseif mode == "UR" then
		Lighting.Technology = Enum.Technology.ShadowMap
		cc.Contrast = 0.55
		cc.Saturation = 0.15
		cc.TintColor = Color3.fromRGB(240, 245, 255)
		bloom.Intensity = 1.2
		bloom.Size = 24
		bloom.Threshold = 0.8
		Lighting.ExposureCompensation = 0
		grain.ImageTransparency = 0.94

	elseif mode == "VHS" then
		Lighting.Technology = Enum.Technology.ShadowMap
		cc.Contrast = 0.5
		cc.Saturation = -0.7
		cc.TintColor = Color3.new(1, 1, 1)
		bloom.Intensity = 0.5
		bloom.Threshold = 0.9
		bloom.Size = 8
		Lighting.ExposureCompensation = -0.2
		grain.ImageTransparency = 0.80

	elseif mode == "Reset" then
		Lighting.Technology = Enum.Technology.ShadowMap
		cc.Enabled = false
		bloom.Enabled = false
		Lighting.ExposureCompensation = 0
		grain.ImageTransparency = 0.94
		motionBlur.Size = 0
	end
end

applyLighting("Normal")

-- WALK SHAKE
local shakeTime = 0
local function getWalkShake(dt)
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not rootPart or not humanoid then return CFrame.new() end
	local vel = rootPart.AssemblyLinearVelocity
	local speed = Vector3.new(vel.X, 0, vel.Z).Magnitude
	local onGround = humanoid.FloorMaterial ~= Enum.Material.Air
	if speed > 0.5 and onGround then
		shakeTime = shakeTime + dt * 9
		local sway = math.sin(shakeTime) * 0.045
		local bob = math.abs(math.sin(shakeTime)) * 0.03
		local tilt = math.sin(shakeTime) * math.rad(0.6)
		return CFrame.new(sway, -bob, 0) * CFrame.Angles(0, 0, tilt)
	else
		shakeTime = shakeTime + dt * 2
		return CFrame.new()
	end
end

