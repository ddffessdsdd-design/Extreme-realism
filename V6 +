-- CORE LOOP
local smoothFlCFrame = CFrame.new()
local grainTimer = 0
local GRAIN_UPDATE_RATE = 0.12
local prevCamCF = camera.CFrame

RunService.RenderStepped:Connect(function(dt)
	if not scriptEnabled then return end

	local shakeCF = getWalkShake(dt)
	camera.CFrame = camera.CFrame * shakeCF

	-- Motion blur from camera movement
	local prevLook = prevCamCF.LookVector
	local currLook = camera.CFrame.LookVector
	local angle = math.acos(math.clamp(prevLook:Dot(currLook), -1, 1))
	prevCamCF = camera.CFrame
	local targetBlur = math.clamp(angle * (180 / math.pi) * 5, 0, 20)
	motionBlur.Size = motionBlur.Size + (targetBlur - motionBlur.Size) * 0.3

	if fl.Enabled then
		smoothFlCFrame = smoothFlCFrame:Lerp(camera.CFrame, dt * 6)
		lightPart.CFrame = smoothFlCFrame
	end

	if effectGui.Enabled then
		grainTimer = grainTimer + dt
		if grainTimer >= GRAIN_UPDATE_RATE then
			grainTimer = 0
			grain.ImageRectOffset = Vector2.new(
				math.random(0, 512),
				math.random(0, 512)
			)
		end
		if analogEnabled then
			local drift = math.sin(tick() * 2) * 1.5
			chromaRed.Position = UDim2.new(0, -2 + drift, 0, 0)
			chromaBlue.Position = UDim2.new(0, 2 - drift, 0, 0)
		end
	end
end)
