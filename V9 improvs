local function setSingleMode(mode, btnMeta, sidePanelEntry)
	if not scriptEnabled then
		return
	end

	local wasOn = (currentMode == mode)

	closeAllSidePanels()

	if wasOn then
		applyMode("Normal")
		if btnMeta then
			setModeButtonVisual(btnMeta, false)
		end
		return
	end

	applyMode(mode)
	if btnMeta then
		setModeButtonVisual(btnMeta, true)
	end
	if sidePanelEntry then
		openSidePanel(sidePanelEntry)
	end
	updateStatus()
end

