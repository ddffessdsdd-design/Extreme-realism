local function repositionAllSidePanels()
	if not refs.panel then
		return
	end

	local sizes = getUiSizes()
	local panelAbsPos = refs.panel.AbsolutePosition
	local panelAbsSize = refs.panel.AbsoluteSize
	local viewport = camera and camera.ViewportSize or Vector2.new(1280, 720)

	local startX = panelAbsPos.X + panelAbsSize.X + SIDE_GAP
	local startY = panelAbsPos.Y
	local currentX = startX
	local currentY = startY
	local stackedBelow = startX + sizes.sideW > viewport.X - 8

	for _, entry in ipairs(refs.sidePanels) do
		if entry.isOpen and entry.frame.Visible then
			if stackedBelow then
				entry.frame.Position = UDim2.new(0, panelAbsPos.X, 0, currentY + panelAbsSize.Y + SIDE_GAP)
				currentY = currentY + entry.frame.AbsoluteSize.Y + SIDE_GAP
			else
				entry.frame.Position = UDim2.new(0, currentX, 0, startY)
				currentX = currentX + entry.frame.AbsoluteSize.X + SIDE_GAP
			end
		end
	end
end

