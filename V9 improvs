	plus.BorderSizePixel = 0
	plus.AutoButtonColor = false
	createCorner(plus, 6)
	local plusStroke = createStroke(plus, 1, theme.accent)

	local function refresh()
		valueLabel.Text = tostring(roundNumber(valueGetter(), 2))
	end

	minus.MouseButton1Click:Connect(function()
		local v = clamp(valueGetter() - step, minV, maxV)
		valueSetter(v)
		refresh()
	end)
	plus.MouseButton1Click:Connect(function()
		local v = clamp(valueGetter() + step, minV, maxV)
		valueSetter(v)
		refresh()
	end)

	table.insert(refs.optionButtons, {btn = minus, stroke = minStroke, active = false})
	table.insert(refs.optionButtons, {btn = plus, stroke = plusStroke, active = false})

	return {
		refresh = refresh,
		row = row,
	}
end

