local function getEffects()
	local cc = safeFindChild(Lighting, "MainCC")
	if not cc then
		cc = Instance.new("ColorCorrectionEffect")
		cc.Name = "MainCC"
		cc.Parent = Lighting
	end

	local bloom = safeFindChild(Lighting, "MainBloom")
	if not bloom then
		bloom = Instance.new("BloomEffect")
		bloom.Name = "MainBloom"
		bloom.Parent = Lighting
	end

	return cc, bloom
end

local function applyFlSettings()
	fl.Brightness = flSettings.brightness
	fl.Range = flSettings.range
	if flSettings.blendColors then
		local a = Lighting.Ambient
		fl.Color = Color3.new(
			(flSettings.color.R + a.R) / 2,
			(flSettings.color.G + a.G) / 2,
			(flSettings.color.B + a.B) / 2
		)
	else
		fl.Color = flSettings.color
	end
end

local function applyMode(mode)
	local cc, bloom = getEffects()
	local cfg = modeConfigs[mode] or modeConfigs.Normal

	currentMode = mode

	effectGui.Enabled = mode ~= "Normal"

	hideAllOverlays()

	Lighting.Technology = Enum.Technology.ShadowMap

	cc.Enabled = true
	bloom.Enabled = true

	local saturation = cfg.saturation
	local contrast = cfg.contrast
	local brightness = cfg.brightness
	local exposure = cfg.exposure
	local bloomIntensity = cfg.bloomIntensity
	local bloomThreshold = cfg.bloomThreshold
	local bloomSize = cfg.bloomSize
	local tint = cfg.tint

	if mode == "VHS" then
		saturation = vhsSettings.saturation
		contrast = vhsSettings.contrast
		exposure = vhsSettings.exposure
	elseif mode == "analog" then
		saturation = ahSettings.saturation
		contrast = ahSettings.contrast
		bloomIntensity = ahSettings.bloom
	end

	cc.TintColor = tint
	cc.Saturation = clamp(saturation + customAdjust.saturation, -1, 1)
	cc.Contrast = clamp(contrast + customAdjust.contrast, -1, 1)
	cc.Brightness = clamp(brightness + customAdjust.brightness, -1, 1)

	Lighting.ExposureCompensation = clamp(exposure + customAdjust.exposure, -5, 5)

	bloom.Intensity = math.max(0, bloomIntensity + customAdjust.bloom)
	bloom.Threshold = clamp(bloomThreshold, 0, 1)
	bloom.Size = math.max(0, bloomSize)

	for overlayName, isVisible in pairs(cfg.overlays or {}) do
		setOverlayVisibility(overlayName, isVisible)
	end

	if mode == "Normal" then
		effectGui.Enabled = false
		cc.Enabled = false
		bloom.Enabled = false
		Lighting.ExposureCompensation = 0
		hideAllOverlays()
	end

	vhsEnabled = (mode == "VHS")
	analogEnabled = (mode == "analog")
	urEnabled = (mode == "UR")
	untitledEnabled = (mode == "untitled")
	pressureEnabled = (mode == "pressure")
	bwEnabled = (mode == "bw")
	crtEnabled = (mode == "crt")
	nightVisionEnabled = (mode == "nightVision")
	thermalEnabled = (mode == "thermal")
	foundFootageEnabled = (mode == "foundFootage")
end

-- ============================================================
-- WALK SHAKE
-- ============================================================
local shakeTime = 0
local function getWalkShake(dt)
	if not cameraShakeEnabled or cameraShakePreset == "Off" then
		return CFrame.new()
	end

	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	if not humanoid or not rootPart then
		return CFrame.new()
	end

	local vel = rootPart.AssemblyLinearVelocity
	local speed = Vector3.new(vel.X, 0, vel.Z).Magnitude
	local moving = speed > 0.8 and humanoid.FloorMaterial ~= Enum.Material.Air
	if not moving then
		shakeTime = shakeTime + dt * 2
		return CFrame.new()
	end

	shakeTime = shakeTime + dt * (8 + speed * 0.15)

	local baseAmp = shakePresets[cameraShakePreset] or 0
	local amplitude = baseAmp * clamp(speed / 16, 0.55, 1.35)

	local x = math.sin(shakeTime * 7.0) * amplitude
	local y = math.abs(math.sin(shakeTime * 11.0)) * amplitude * 0.65
	local z = math.sin(shakeTime * 4.5) * amplitude * 0.45
	local roll = math.sin(shakeTime * 5.5) * math.rad(0.35 + (amplitude * 80))

	return CFrame.new(x, -y, z) * CFrame.Angles(0, 0, roll)
end

