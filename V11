local function getEffects()
	local cc = safeFindChild(Lighting, "MainCC")
	if not cc then
		cc = Instance.new("ColorCorrectionEffect")
		cc.Name = "MainCC"
		cc.Parent = Lighting
	end
	local bloom = safeFindChild(Lighting, "MainBloom")
	if not bloom then
		bloom = Instance.new("BloomEffect")
		bloom.Name = "MainBloom"
		bloom.Parent = Lighting
	end
	return cc, bloom
end

local function applyFlSettings()
	fl.Brightness = State.flSettings.brightness
	fl.Range = State.flSettings.range
	if State.flSettings.blendColors then
		local a = Lighting.Ambient
		fl.Color = Color3.new(
			(State.flSettings.color.R + a.R) / 2,
			(State.flSettings.color.G + a.G) / 2,
			(State.flSettings.color.B + a.B) / 2
		)
	else
		fl.Color = State.flSettings.color
	end
end

local savedAmbient = Lighting.Ambient
local savedOutdoorAmbient = Lighting.OutdoorAmbient

local function applyColorTint()
	if not State.colorTintEnabled then
		Lighting.Ambient = savedAmbient
		Lighting.OutdoorAmbient = savedOutdoorAmbient
		return
	end
	local col = hsvToColor3(State.colorTintHue, State.colorTintSaturation, State.colorTintBrightness)
	local tintedAmbient = Color3.new(
		clamp(col.R * 0.5, 0, 1),
		clamp(col.G * 0.5, 0, 1),
		clamp(col.B * 0.5, 0, 1)
	)
	Lighting.Ambient = tintedAmbient
	Lighting.OutdoorAmbient = Color3.new(
		clamp(col.R * 0.7, 0, 1),
		clamp(col.G * 0.7, 0, 1),
		clamp(col.B * 0.7, 0, 1)
	)
end

