-- ============================================================
-- WALK SHAKE / VIEW BOBBING
-- ============================================================
local shakeTime = 0

local function getWalkShake(dt)
	if (not State.cameraShakeEnabled or State.cameraShakePreset == "Off") and not State.viewBobbingEnabled then
		return CFrame.new()
	end
	
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	if not humanoid or not rootPart then return CFrame.new() end
	
	local vel = rootPart.AssemblyLinearVelocity
	local speed = Vector3.new(vel.X, 0, vel.Z).Magnitude
	local moving = speed > 0.8 and humanoid.FloorMaterial ~= Enum.Material.Air
	
	shakeTime = shakeTime + dt * (moving and (7 + speed * 0.18) * State.viewBobbingSpeed or 1.8)
	
	local baseAmp = shakePresets[State.cameraShakePreset] or 0
	local bobAmp = State.viewBobbingEnabled and clamp(State.viewBobbingIntensity, 0, 1) or 0
	local amplitude = baseAmp + (bobAmp * 0.012)
	
	if not moving then
		local breatheY = math.sin(shakeTime * 1.15) * (0.010 + bobAmp * 0.010)
		local breatheX = math.sin(shakeTime * 0.8) * (0.006 + bobAmp * 0.004)
		return CFrame.new(breatheX, breatheY, 0)
	end
	
	local x = math.sin(shakeTime * 6.3) * (0.010 + amplitude)
	local y = math.abs(math.sin(shakeTime * 9.0)) * (0.016 + amplitude * 1.7)
	local z = math.sin(shakeTime * 4.2) * (0.008 + amplitude * 0.8)
	local roll = math.sin(shakeTime * 5.0) * math.rad(0.25 + (amplitude * 55))
	return CFrame.new(x, -y, z) * CFrame.Angles(0, 0, roll)
end

