applyTheme = function()
	theme = themePresets[State.themeName] or themePresets["Obsidian"]
	gradientTheme = gradientPresets[State.gradientName] or gradientPresets["Crimson Fade"]
	
	if refs.panel then refs.panel.BackgroundColor3 = theme.bg end
	if refs.panelStroke then refs.panelStroke.Color = theme.stroke end
	if refs.panelGrad then
		refs.panelGrad.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, theme.bg2),
			ColorSequenceKeypoint.new(1, theme.bg),
		})
	end
	if refs.titleBar then refs.titleBar.BackgroundColor3 = theme.panelTop end
	if refs.titleGrad then
		refs.titleGrad.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, gradientTheme.top),
			ColorSequenceKeypoint.new(1, gradientTheme.bottom),
		})
	end
	if refs.titleLabel then refs.titleLabel.TextColor3 = theme.text end
	if refs.titleAccent then refs.titleAccent.BackgroundColor3 = theme.accent end
	if refs.statusBox then refs.statusBox.BackgroundColor3 = theme.bg2 end
	if refs.statusStroke then refs.statusStroke.Color = theme.accent end
	if refs.statusTitle then refs.statusTitle.TextColor3 = theme.accent end
	if refs.statusLabel then refs.statusLabel.TextColor3 = theme.text end
	if reopenBtn then
		reopenBtn.BackgroundColor3 = theme.bg2
		refs.reopenStroke.Color = theme.accent
		reopenBtn.TextColor3 = theme.text
	end
	if closeBtn then closeBtn.BackgroundColor3 = theme.accent end
	if refs.div1 then refs.div1.BackgroundColor3 = theme.divider end
	if refs.divStatus then refs.divStatus.BackgroundColor3 = theme.divider end
	
	for _, entry in ipairs(refs.sidePanels) do
		if entry.frame then
			entry.frame.BackgroundColor3 = theme.bg
			entry.stroke.Color = theme.stroke
			entry.grad.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, theme.bg2),
				ColorSequenceKeypoint.new(1, theme.bg),
			})
			entry.head.BackgroundColor3 = theme.panelTop
			entry.headStroke.Color = theme.accent
			entry.headGrad.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, gradientTheme.top),
				ColorSequenceKeypoint.new(1, gradientTheme.bottom),
			})
			entry.headLabel.TextColor3 = theme.text
		end
	end
	
	for _, meta in ipairs(refs.modeButtons) do
		setModeButtonState(meta, meta.active, meta.onLabel, meta.offLabel)
	end
	for _, meta in ipairs(refs.optionButtons) do
		setOptButtonState(meta, meta.active)
	end
end

applyUiMode = function()
	State.resolvedUiMode = getResolvedUiMode()
	local sz = getUiSizes()
	if panel then
		panel.Size = UDim2.new(0, sz.panelW, 0, sz.panelH)
		panel.Position = UDim2.new(0, 16, 0.5, -math.floor(sz.panelH / 2))
	end
	if buttonScroll then
		buttonScroll.ScrollBarThickness = State.resolvedUiMode == "Phone" and 3 or 4
	end
	if refs.titleLabel then refs.titleLabel.TextSize = sz.titleSize end
	if refs.statusTitle then refs.statusTitle.TextSize = sz.statusSize end
	if statusLabel then statusLabel.TextSize = sz.statusSize + 1 end
	if reopenBtn then
		reopenBtn.Size = UDim2.new(0, State.resolvedUiMode == "PC" and 38 or 34, 0, State.resolvedUiMode == "PC" and 38 or 34)
	end
	for _, meta in ipairs(refs.modeButtons) do
		meta.btn.Size = UDim2.new(1, 0, 0, sz.buttonH)
		meta.label.TextSize = sz.buttonTextSize
	end
	for _, entry in ipairs(refs.sidePanels) do
		if entry.frame then
			entry.frame.Size = UDim2.new(0, sz.sideW, 0, sz.sideH)
		end
	end
end

refreshSidePanelSizes = function()
	local sz = getUiSizes()
	for _, entry in ipairs(refs.sidePanels) do
		entry.frame.Size = UDim2.new(0, sz.sideW, 0, sz.sideH)
	end
end

closeAllSidePanels = function()
	for _, entry in ipairs(refs.sidePanels) do
		entry.isOpen = false
		if entry.frame then entry.frame.Visible = false end
	end
end

repositionAllSidePanels = function()
	if not panel then return end
	local sz = getUiSizes()
	local panelAbsPos = panel.AbsolutePosition
	local panelAbsSize = panel.AbsoluteSize
	local viewport = camera and camera.ViewportSize or Vector2.new(1280, 720)
	local startX = panelAbsPos.X + panelAbsSize.X + SIDE_GAP
	local startY = panelAbsPos.Y
	local currentX = startX
	local currentY = startY
	local stackedBelow = startX + sz.sideW > viewport.X - 8
	
	for _, entry in ipairs(refs.sidePanels) do
		if entry.isOpen and entry.frame.Visible then
			if stackedBelow then
				entry.frame.Position = UDim2.new(0, panelAbsPos.X, 0, currentY + panelAbsSize.Y + SIDE_GAP)
				currentY = currentY + entry.frame.AbsoluteSize.Y + SIDE_GAP
			else
				entry.frame.Position = UDim2.new(0, currentX, 0, startY)
				currentX = currentX + entry.frame.AbsoluteSize.X + SIDE_GAP
			end
		end
	end
end

openSidePanel = function(entry)
	entry.isOpen = true
	entry.frame.Visible = true
	repositionAllSidePanels()
end

closeSidePanel = function(entry)
	entry.isOpen = false
	entry.frame.Visible = false
	repositionAllSidePanels()
end

