	end
	
	local function saveProfile(profileName)
		profileName = sanitizeProfileName(profileName)
		local json = HttpService:JSONEncode(buildProfileData())
		if type(writefile) == "function" and type(isfolder) == "function" and type(makefolder) == "function" then
			pcall(function()
				if not isfolder(State.profileStorageFolder) then makefolder(State.profileStorageFolder) end
				writefile(State.profileStorageFolder .. "/" .. profileName .. ".json", json)
			end)
		end
		State.savedProfiles[profileName] = json
		refs.profileStatusLbl.Text = "Saved: " .. profileName
		refreshProfileList()
	end
	
	local function loadProfileFromJson(json)
		local ok, data = pcall(function() return HttpService:JSONDecode(json) end)
		if not ok or type(data) ~= "table" then return false end
		
		State.isLoadingProfile = true
		
		State.currentMode = data.currentMode or "Normal"
		State.scriptEnabled = data.scriptEnabled ~= false
		State.guiHidden = data.guiHidden == true
		State.uiModeSetting = data.uiModeSetting or State.uiModeSetting
		State.themeName = data.themeName or State.themeName
		State.gradientName = data.gradientName or State.gradientName
		State.cameraShakePreset = data.cameraShakePreset or State.cameraShakePreset
		State.cameraShakeEnabled = data.cameraShakeEnabled == true
		State.viewBobbingEnabled = data.viewBobbingEnabled == true
		State.viewBobbingIntensity = tonumber(data.viewBobbingIntensity) or State.viewBobbingIntensity
		State.viewBobbingSpeed = tonumber(data.viewBobbingSpeed) or State.viewBobbingSpeed
		State.bwBrightness = tonumber(data.bwBrightness) or State.bwBrightness
		State.bwContrast = tonumber(data.bwContrast) or State.bwContrast
		State.pressureIntensity = tonumber(data.pressureIntensity) or State.pressureIntensity
		State.glossyIntensity = tonumber(data.glossyIntensity) or State.glossyIntensity
		State.flashlightEnabled = data.flashlightEnabled == true
		State.motionBlurEnabled = data.motionBlurEnabled == true
		State.colorTintEnabled = data.colorTintEnabled == true
		State.colorTintHue = tonumber(data.colorTintHue) or State.colorTintHue
		State.colorTintSaturation = tonumber(data.colorTintSaturation) or State.colorTintSaturation
		State.colorTintBrightness = tonumber(data.colorTintBrightness) or State.colorTintBrightness
		State.audioEchoEnabled = data.audioEchoEnabled == true
		State.audioReverbEnabled = data.audioReverbEnabled == true
		State.audioPitchEnabled = data.audioPitchEnabled == true
		State.audioPitchValue = tonumber(data.audioPitchValue) or State.audioPitchValue
		State.audioEchoDelay = tonumber(data.audioEchoDelay) or State.audioEchoDelay
		State.audioEchoFeedback = tonumber(data.audioEchoFeedback) or State.audioEchoFeedback
		
		if type(data.customAdjust) == "table" then
			State.customAdjust.saturation = tonumber(data.customAdjust.saturation) or State.customAdjust.saturation
			State.customAdjust.contrast = tonumber(data.customAdjust.contrast) or State.customAdjust.contrast
			State.customAdjust.brightness = tonumber(data.customAdjust.brightness) or State.customAdjust.brightness
			State.customAdjust.bloom = tonumber(data.customAdjust.bloom) or State.customAdjust.bloom
			State.customAdjust.exposure = tonumber(data.customAdjust.exposure) or State.customAdjust.exposure
		end
		
		if type(data.flSettings) == "table" then
			State.flSettings.brightness = tonumber(data.flSettings.brightness) or State.flSettings.brightness
			State.flSettings.heaviness = tonumber(data.flSettings.heaviness) or State.flSettings.heaviness
			State.flSettings.range = tonumber(data.flSettings.range) or State.flSettings.range
			State.flSettings.blendColors = data.flSettings.blendColors == true
			if type(data.flSettings.color) == "table" then
				local r = clamp(tonumber(data.flSettings.color.R) or 1, 0, 1)
				local g = clamp(tonumber(data.flSettings.color.G) or 1, 0, 1)
				local b = clamp(tonumber(data.flSettings.color.B) or 1, 0, 1)
				State.flSettings.color = Color3.new(r, g, b)
			end
		end
		
		if type(data.mbSettings) == "table" then
			State.mbSettings.strength = tonumber(data.mbSettings.strength) or State.mbSettings.strength
			State.mbSettings.speed = tonumber(data.mbSettings.speed) or State.mbSettings.speed
		end
		if type(data.vhsSettings) == "table" then
			State.vhsSettings.contrast = tonumber(data.vhsSettings.contrast) or State.vhsSettings.contrast
			State.vhsSettings.saturation = tonumber(data.vhsSettings.saturation) or State.vhsSettings.saturation
			State.vhsSettings.exposure = tonumber(data.vhsSettings.exposure) or State.vhsSettings.exposure
		end
		if type(data.ahSettings) == "table" then
			State.ahSettings.contrast = tonumber(data.ahSettings.contrast) or State.ahSettings.contrast
			State.ahSettings.saturation = tonumber(data.ahSettings.saturation) or State.ahSettings.saturation
			State.ahSettings.bloom = tonumber(data.ahSettings.bloom) or State.ahSettings.bloom
		end
		
		applyUiMode()
		applyTheme()
		refreshSidePanelSizes()
		applyFlSettings()
		applyMode(State.currentMode)
		applyAudioFX()
		refreshEffectButtons()
		
		fl.Enabled = State.flashlightEnabled
		if not State.motionBlurEnabled then motionBlur.Size = 0 end
		
		local function setMainPanelVisible(visible)
			State.mainPanelVisible = visible
			if panel then panel.Visible = visible end
			for _, entry in ipairs(refs.sidePanels) do
				entry.frame.Visible = visible and entry.isOpen or false
			end
			if reopenBtn then reopenBtn.Visible = not visible end
		end
		setMainPanelVisible(true)
		
		State.isLoadingProfile = false
		State.profileDirty = false
		return true
	end
	
	loadProfile = function(profileName)
		profileName = sanitizeProfileName(profileName)
		local json
		
		if type(readfile) == "function" and type(isfile) == "function" then
			local ok, result = pcall(function()
				if isfile(State.profileStorageFolder .. "/" .. profileName .. ".json") then
					return readfile(State.profileStorageFolder .. "/" .. profileName .. ".json")
				end
			end)
			if ok then json = result end
		end
		
		if not json and State.savedProfiles[profileName] then
			json = State.savedProfiles[profileName]
		end
		
		if not json then
			refs.profileStatusLbl.Text = "Not found: " .. profileName
			return false
		end
		
		return loadProfileFromJson(json)
	end
	
	refreshProfileList = function()
		for _, child in ipairs(refs.profileListFrame:GetChildren()) do
			if child ~= refs.profileListLayout then
				child:Destroy()
			end
		end
		
		local names = {}
		for k in pairs(State.savedProfiles) do table.insert(names, k) end
		table.sort(names)
		
		if #names == 0 then
			refs.profileListFrame.Size = UDim2.new(1, 0, 0, 4)
			return
		end
		
		for i, name in ipairs(names) do
			local entryRow = Instance.new("Frame")
			entryRow.Parent = refs.profileListFrame
			entryRow.Size = UDim2.new(1, 0, 0, 24)
			entryRow.BackgroundTransparency = 1
			entryRow.LayoutOrder = i
			
			local entryLayout = Instance.new("UIListLayout")
			entryLayout.Parent = entryRow
			entryLayout.FillDirection = Enum.FillDirection.Horizontal
			entryLayout.Padding = UDim.new(0, 3)
			
			local entryLbl = Instance.new("TextButton")
			entryLbl.Parent = entryRow
			entryLbl.Size = UDim2.new(0.70, -3, 0, 24)
			entryLbl.BackgroundColor3 = theme.bg2
			entryLbl.Text = name
			entryLbl.TextColor3 = theme.text
			entryLbl.TextSize = 9
			entryLbl.Font = Enum.Font.GothamSemibold
			entryLbl.BorderSizePixel = 0
			entryLbl.AutoButtonColor = false
			entryLbl.LayoutOrder = 1
			entryLbl.TextXAlignment = Enum.TextXAlignment.Left
			local ep = Instance.new("UIPadding")
			ep.Parent = entryLbl
			ep.PaddingLeft = UDim.new(0, 6)
			createCorner(entryLbl, 6)
			createStroke(entryLbl, 1, theme.stroke)
			
			local delBtn = Instance.new("TextButton")
			delBtn.Parent = entryRow
			delBtn.Size = UDim2.new(0.30, -3, 0, 24)
			delBtn.BackgroundColor3 = theme.accentSoft
			delBtn.Text = "DEL"
			delBtn.TextColor3 = theme.text
			delBtn.TextSize = 9
			delBtn.Font = Enum.Font.GothamBold
			delBtn.BorderSizePixel = 0
			delBtn.AutoButtonColor = false
			delBtn.LayoutOrder = 2
			createCorner(delBtn, 6)
			createStroke(delBtn, 1, theme.accent)
		end
		
		refs.profileListFrame.Size = UDim2.new(1, 0, 0, #names * 27 + 4)
	end
	
	saveProfileBtn.MouseButton1Click:Connect(function()
		local name = refs.profileNameBox.Text
		if name == "" then name = State.autoProfileName end
		saveProfile(name)
		State.profileDirty = false
	end)
	
	loadProfileBtn.MouseButton1Click:Connect(function()
		local name = refs.profileNameBox.Text
		if name == "" then name = State.autoProfileName end
		loadProfile(name)
	end)
	
	refs.saveProfileBtn = saveProfileBtn
	refs.loadProfileBtn = loadProfileBtn
end

