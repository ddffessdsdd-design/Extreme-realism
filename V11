local function clamp(v, minV, maxV)
	return math.max(minV, math.min(maxV, v))
end

local function safeFindChild(parent, name)
	return parent:FindFirstChild(name)
end

local function detectDeviceMode()
	if UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled then
		return "Phone"
	end
	if UserInputService.TouchEnabled and UserInputService.KeyboardEnabled then
		return "Tablet"
	end
	return "PC"
end

local function roundNumber(n, decimals)
	local p = 10 ^ (decimals or 0)
	return math.floor(n * p + 0.5) / p
end

local function hsvToColor3(h, s, v)
	if s == 0 then return Color3.new(v, v, v) end
	local i = math.floor(h * 6)
	local f = h * 6 - i
	local p = v * (1 - s)
	local q = v * (1 - f * s)
	local t = v * (1 - (1 - f) * s)
	i = i % 6
	if i == 0 then return Color3.new(v, t, p)
	elseif i == 1 then return Color3.new(q, v, p)
	elseif i == 2 then return Color3.new(p, v, t)
	elseif i == 3 then return Color3.new(p, q, v)
	elseif i == 4 then return Color3.new(t, p, v)
	else return Color3.new(v, p, q) end
end

