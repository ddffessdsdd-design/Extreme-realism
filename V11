updateStatus = function()
	local parts = {}
	if State.currentMode ~= "Normal" then table.insert(parts, "◆ " .. State.currentMode:upper()) end
	if State.flashlightEnabled then table.insert(parts, "◆ FL") end
	if State.motionBlurEnabled then table.insert(parts, "◆ MB") end
	if State.colorTintEnabled then table.insert(parts, "◆ TINT") end
	if State.audioEchoEnabled or State.audioReverbEnabled or State.audioPitchEnabled then
		table.insert(parts, "◆ AUDIO")
	end
	if State.viewBobbingEnabled then table.insert(parts, "◆ BOB") end
	if State.guiHidden then table.insert(parts, "◆ UI HIDDEN") end
	if not State.scriptEnabled then table.insert(parts, "◆ DISABLED") end
	statusLabel.Text = (#parts > 0) and table.concat(parts, "  ") or "None"
	
	if State.autoSaveReady and State.profileDirty and not State.isLoadingProfile then
		-- saveProfile(State.autoProfileName)
		State.profileDirty = false
	end
end

