		if State.flashlightEnabled then
			applyFlSettings()
			openSidePanel(flPanel)
		else
			closeSidePanel(flPanel)
		end
		updateStatus()
		State.profileDirty = true
	end)
	
	-- Motion Blur
	btnMB.btn.MouseButton1Click:Connect(function()
		State.motionBlurEnabled = not State.motionBlurEnabled
		if not State.motionBlurEnabled then motionBlur.Size = 0 end
		setModeButtonState(btnMB, State.motionBlurEnabled, "MOTION BLUR ⚡", "MOTION BLUR ⚡")
		if State.motionBlurEnabled then openSidePanel(mbPanel) else closeSidePanel(mbPanel) end
		updateStatus()
		State.profileDirty = true
	end)
	
	-- Color Tint
	btnColorTint.btn.MouseButton1Click:Connect(function()
		State.colorTintEnabled = not State.colorTintEnabled
		setModeButtonState(btnColorTint, State.colorTintEnabled, "COLOR TINT ⚡", "COLOR TINT ⚡")
		if refs.colorTintToggle then
			refs.colorTintToggle.active = State.colorTintEnabled
			refs.colorTintToggle.btn.Text = State.colorTintEnabled and "Color Tint: ON" or "Color Tint: OFF"
			setOptButtonState(refs.colorTintToggle, State.colorTintEnabled)
		end
		applyColorTint()
		if State.colorTintEnabled then openSidePanel(colorTintPanel) else closeSidePanel(colorTintPanel) end
		updateStatus()
		State.profileDirty = true
	end)
	
	-- Audio FX
	btnAudio.btn.MouseButton1Click:Connect(function()
		local anyOn = State.audioEchoEnabled or State.audioReverbEnabled or State.audioPitchEnabled
		if anyOn then
			closeSidePanel(audioPanel)
			setModeButtonState(btnAudio, false, "AUDIO FX ⚡", "AUDIO FX ⚡")
		else
			openSidePanel(audioPanel)
			setModeButtonState(btnAudio, true, "AUDIO FX ⚡", "AUDIO FX ⚡")
		end
		updateStatus()
		State.profileDirty = true
	end)
	
	-- Settings
	btnSettings.btn.MouseButton1Click:Connect(function()
		if settingsPanel.isOpen then
			closeSidePanel(settingsPanel)
			setModeButtonState(btnSettings, false, "SETTINGS ⚡", "SETTINGS ⚡")
		else
			openSidePanel(settingsPanel)
			setModeButtonState(btnSettings, true, "SETTINGS ⚡", "SETTINGS ⚡")
		end
		updateStatus()
	end)
	
	-- Hide UI
	btnHideUI.btn.MouseButton1Click:Connect(function()
		State.guiHidden = not State.guiHidden
		-- setMainPanelVisible(not State.guiHidden)
		if panel then panel.Visible = not State.guiHidden end
		for _, entry in ipairs(refs.sidePanels) do
			entry.frame.Visible = not State.guiHidden and entry.isOpen or false
		end
		if reopenBtn then reopenBtn.Visible = State.guiHidden end
		setModeButtonState(btnHideUI, State.guiHidden, "HIDE UI", "HIDE UI")
		updateStatus()
		State.profileDirty = true
	end)
	
	-- Master toggle
	btnToggle.btn.MouseButton1Click:Connect(function()
		State.scriptEnabled = not State.scriptEnabled
		if not State.scriptEnabled then
			State.currentMode = "Normal"
			applyMode("Normal")
			State.flashlightEnabled = false
			fl.Enabled = false
			State.motionBlurEnabled = false
			motionBlur.Size = 0
			State.colorTintEnabled = false
			applyColorTint()
			State.audioEchoEnabled = false
			State.audioReverbEnabled = false
			State.audioPitchEnabled = false
			applyAudioFX()
			closeAllSidePanels()
			refreshEffectButtons()
			setModeButtonState(btnFL, false, "FLASHLIGHT ⚡", "FLASHLIGHT ⚡")
			setModeButtonState(btnMB, false, "MOTION BLUR ⚡", "MOTION BLUR ⚡")
			setModeButtonState(btnColorTint, false, "COLOR TINT ⚡", "COLOR TINT ⚡")
			setModeButtonState(btnAudio, false, "AUDIO FX ⚡", "AUDIO FX ⚡")
			setModeButtonState(btnSettings, false, "SETTINGS ⚡", "SETTINGS ⚡")
			setModeButtonState(btnToggle, false, "ENABLED", "DISABLED")
		else
			applyMode("Normal")
			setModeButtonState(btnToggle, true, "ENABLED", "DISABLED")
		end
		updateStatus()
		State.profileDirty = true
	end)
	
	-- Close / reopen
	closeBtn.MouseButton1Click:Connect(function()
		State.mainPanelVisible = false
		if panel then panel.Visible = false end
		for _, entry in ipairs(refs.sidePanels) do
			entry.frame.Visible = false
		end
		if reopenBtn then reopenBtn.Visible = true end
	end)
	reopenBtn.MouseButton1Click:Connect(function()
		State.mainPanelVisible = true
		if panel then panel.Visible = true end
		for _, entry in ipairs(refs.sidePanels) do
			entry.frame.Visible = entry.isOpen or false
		end
		if reopenBtn then reopenBtn.Visible = false end
		repositionAllSidePanels()
	end)
end

