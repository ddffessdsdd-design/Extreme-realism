-- ============================================================
-- DRAG HANDLING
-- ============================================================
local dragging = false
local dragStart = nil
local startPos = nil

local function setupDrag()
	local titleBarFrame = refs.titleBar
	if not titleBarFrame then return end
	
	titleBarFrame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = panel.Position
		end
	end)
	
	titleBarFrame.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if not dragging then return end
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			local delta = input.Position - dragStart
			panel.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
			repositionAllSidePanels()
		end
	end)
end

-- ============================================================
-- RENDER LOOP
-- ============================================================
local prevCamCF = camera.CFrame
local smoothFlCFrame = CFrame.new()
local scanlineTimer = 0
local acidTimer = 0
local dreamTimer = 0
local waterTimer = 0

local function refreshScanlines()
	local viewport = (camera and camera.ViewportSize) or Vector2.new(1280, 720)
	local spacing = math.max(4, math.floor(viewport.Y / #Overlays.scanlineBars))
	local offset = math.floor((tick() * 20) % spacing)
	for i, bar in ipairs(Overlays.scanlineBars) do
		bar.Size = UDim2.new(1, 0, 0, 1)
		bar.Position = UDim2.new(0, 0, 0, ((i - 1) * spacing + offset) % viewport.Y)
	end
end

local function startRenderLoop()
	RunService.RenderStepped:Connect(function(dt)
		if not camera then
			camera = workspace.CurrentCamera
			if not camera then return end
		end
		
		if State.scriptEnabled and (State.cameraShakeEnabled or State.viewBobbingEnabled) then
			camera.CFrame = camera.CFrame * getWalkShake(dt)
		end
		
		if State.motionBlurEnabled then
			local dot = prevCamCF.LookVector:Dot(camera.CFrame.LookVector)
			local diff = math.deg(math.acos(clamp(dot, -1, 1)))
			local trigger = State.mbSettings.speed
			local ratio = clamp((diff - trigger) / trigger, 0, 1)
			motionBlur.Size = motionBlur.Size + (ratio * State.mbSettings.strength - motionBlur.Size) * 0.25
		else
			motionBlur.Size = 0
		end
		
		prevCamCF = camera.CFrame
		
		if State.flashlightEnabled then
			local lerpSpeed = clamp((1 - State.flSettings.heaviness) * 14, 0.5, 14)
			smoothFlCFrame = smoothFlCFrame:Lerp(camera.CFrame, dt * lerpSpeed)
			lightPart.CFrame = smoothFlCFrame
		end
		
		if effectGui.Enabled then
			local mode = State.currentMode
			if mode == "VHS" or mode == "analog" or mode == "crt" or mode == "foundFootage" or mode == "nightVision" then
				scanlineTimer = scanlineTimer + dt
				if scanlineTimer >= 0.10 then
					scanlineTimer = 0
					refreshScanlines()
				end
			end
			
			if mode == "analog" or mode == "crt" then
				local drift = math.sin(tick() * 2) * 1.5
				Overlays.chromaRed.Position = UDim2.new(0, -2 + drift, 0, 0)
				Overlays.chromaBlue.Position = UDim2.new(0, 2 - drift, 0, 0)
			end
			
			if mode == "bw" then
				Overlays.bwGlow.BackgroundTransparency = 0.94 + math.sin(tick() * 2) * 0.01
			end
			
			if mode == "pressure" then
				local intens = State.pressureIntensity
				Overlays.pressureTint.BackgroundTransparency = (0.75 - intens * 0.06) + math.sin(tick() * 1.5) * 0.02
			end
			
			if mode == "glossy" then
				local glossyGrad = Overlays.glossyShine:FindFirstChildOfClass("UIGradient")
				if glossyGrad then
					glossyGrad.Rotation = (math.floor(tick() * 20) % 360)
				end
				Overlays.glossyShine.BackgroundTransparency = 0.80 + math.sin(tick() * 1.8) * 0.05
			end
			
			if mode == "retro" then
				Overlays.retroGrain.BackgroundTransparency = 0.88 + math.sin(tick() * 40) * 0.06
			end
			
			if mode == "acid" then
				acidTimer = acidTimer + dt
				local h = (acidTimer * 0.5) % 1
				Overlays.acidPulse.BackgroundColor3 = hsvToColor3(h, 0.8, 0.6)
				Overlays.acidPulse.BackgroundTransparency = 0.90 + math.sin(tick() * 6) * 0.05
			end
			
			if mode == "dream" then
				dreamTimer = dreamTimer + dt
				local dh = (dreamTimer * 0.2) % 1
				Overlays.dreamBloom.BackgroundColor3 = hsvToColor3(dh, 0.3, 0.8)
				Overlays.dreamBloom.BackgroundTransparency = 0.88 + math.sin(tick() * 0.8) * 0.03
			end
			
			if mode == "horror" then
				Overlays.horrorTint.BackgroundTransparency = 0.82 + math.sin(tick() * 2.5) * 0.06
			end
			
			if mode == "underwater" then
				waterTimer = waterTimer + dt
				Overlays.waterOverlay.BackgroundTransparency = 0.91 + math.sin(waterTimer * 3) * 0.04
				local cc2 = safeFindChild(Lighting, "MainCC")
				if cc2 then
					cc2.Saturation = 0.10 + math.sin(waterTimer * 1.5) * 0.02
				end
			end
		end
	end)
end

-- ============================================================
-- INITIALIZATION
-- ============================================================
local function init()
	buildMainUI()
	buildSidePanels()
	buildModeButtons()
	
	applyUiMode()
	applyTheme()
	refreshSidePanelSizes()
	applyFlSettings()
	applyMode("Normal")
	refreshEffectButtons()
	
	setModeButtonState(btnSettings, false, "SETTINGS ⚡", "SETTINGS ⚡")
	setModeButtonState(btnFL, false, "FLASHLIGHT ⚡", "FLASHLIGHT ⚡")
	setModeButtonState(btnMB, false, "MOTION BLUR ⚡", "MOTION BLUR ⚡")
	setModeButtonState(btnColorTint, false, "COLOR TINT ⚡", "COLOR TINT ⚡")
	setModeButtonState(btnAudio, false, "AUDIO FX ⚡", "AUDIO FX ⚡")
	setModeButtonState(btnHideUI, false, "HIDE UI", "HIDE UI")
	setModeButtonState(btnToggle, true, "ENABLED", "DISABLED")
	
	repositionAllSidePanels()
	setupDrag()
	refreshProfileList()
	
	-- Load autosave
	local function tryLoadAutosave()
		State.autoSaveReady = false
		if type(listfiles) == "function" and type(isfolder) == "function" then
			pcall(function()
				if isfolder(State.profileStorageFolder) then
					local files = listfiles(State.profileStorageFolder)
					for _, path in ipairs(files) do
						local name = path:match("([^/\\]+)%.json$")
						if name then
							local ok, content = pcall(readfile, path)
							if ok and content then
								State.savedProfiles[name] = content
							end
						end
					end
				end
			end)
		end
		refreshProfileList()
		if State.savedProfiles[State.autoProfileName] then
			loadProfile(State.autoProfileName)
		end
		State.autoSaveReady = true
		State.profileDirty = false
	end
	
	tryLoadAutosave()
	applyLighting(State.currentMode)
	refreshEffectButtons()
	updateStatus()
	
	startRenderLoop()
	
	-- Events
	workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
		camera = workspace.CurrentCamera or camera
	end)
	
	if camera then
		camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
			refreshSidePanelSizes()
			repositionAllSidePanels()
			if effectGui.Enabled then refreshScanlines() end
		end)
	end
	
	player.CharacterAdded:Connect(function(newCharacter)
		character = newCharacter
	end)
	
	-- Keyboard shortcuts
	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end
		if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
		if input.KeyCode == Enum.KeyCode.P then
			if getResolvedUiMode() == "PC" then
				local newVisible = not State.mainPanelVisible
				State.mainPanelVisible = newVisible
				if panel then panel.Visible = newVisible end
				for _, entry in ipairs(refs.sidePanels) do
					entry.frame.Visible = newVisible and entry.isOpen or false
				end
				if reopenBtn then reopenBtn.Visible = not newVisible end
				repositionAllSidePanels()
			end
		end
	end)
end

init()
