local function resetShaders()
	vhsEnabled = false; analogEnabled = false; urEnabled = false; untitledEnabled = false
	setState(btnVHS,      dotVHS,      sVHS,      false, "VHS")
	setState(btnAH,       dotAH,       sAH,       false, "ANALOG HORROR")
	setState(btnUR,       dotUR,       sUR,       false, "ULTRA REAL")
	setState(btnUntitled, dotUntitled, sUntitled, false, "UNTITLED")
	effectGui.Enabled = false
end

btnVHS.MouseButton1Click:Connect(function()
