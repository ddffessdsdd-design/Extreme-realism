-- DRAG
local dragging, dragStart, startPos = false, nil, nil
titleBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true; dragStart = input.Position; startPos = panel.Position
	end
end)
titleBar.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)
UserInputService.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
		or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		panel.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
		repositionSidePanels()
	end
end)

-- CORE LOOP
local smoothFlCFrame = CFrame.new()
local grainTimer = 0
local GRAIN_RATE = 0.12
local prevCamCF = camera.CFrame

RunService.RenderStepped:Connect(function(dt)
	if not scriptEnabled then return end

	local shakeCF = getWalkShake(dt)
	camera.CFrame = camera.CFrame * shakeCF

	if motionBlurEnabled then
		local angle = math.deg(math.acos(math.clamp(
			prevCamCF.LookVector:Dot(camera.CFrame.LookVector), -1, 1)))
		local ratio = math.clamp((angle - mbSettings.speed) / mbSettings.speed, 0, 1)
		local target = ratio * mbSettings.strength
		motionBlur.Size = motionBlur.Size + (target - motionBlur.Size) * 0.25
	else
		motionBlur.Size = 0
	end
	prevCamCF = camera.CFrame

	if fl.Enabled then
		local lerpSpeed = math.clamp((1 - flSettings.heaviness) * 14, 0.5, 14)
		smoothFlCFrame = smoothFlCFrame:Lerp(camera.CFrame, dt * lerpSpeed)
		lightPart.CFrame = smoothFlCFrame
	end

	if effectGui.Enabled then
		grainTimer = grainTimer + dt
		if grainTimer >= GRAIN_RATE then
			grainTimer = 0
			grain.ImageRectOffset = Vector2.new(math.random(0, 512), math.random(0, 512))
		end
		if analogEnabled then
			local drift = math.sin(tick() * 2) * 1.5
			chromaRed.Position = UDim2.new(0, -2 + drift, 0, 0)
			chromaBlue.Position = UDim2.new(0, 2 - drift, 0, 0)
		end
	end
end)
