	local wasOn = vhsEnabled; resetShaders()
	if not wasOn then
		vhsEnabled = true; effectGui.Enabled = true
		applyLighting("VHS"); setState(btnVHS, dotVHS, sVHS, true, "VHS")
	else applyLighting("Normal") end
	updateStatus()
end)

