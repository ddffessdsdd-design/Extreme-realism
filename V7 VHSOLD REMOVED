local mbPanel, mbList = makeSidePanel("◎ MOTION BLUR")

local function repositionSidePanels()
	local panelAbsPos  = panel.AbsolutePosition
	local panelAbsSize = panel.AbsoluteSize
	local sideX = panelAbsPos.X + panelAbsSize.X + SIDE_X_OFFSET

	local currentY = panelAbsPos.Y

	if flPanel.Visible then
		flPanel.Position = UDim2.new(0, sideX, 0, currentY)
		currentY = currentY + flPanel.AbsoluteSize.Y + 6
	end
	if mbPanel.Visible then
		mbPanel.Position = UDim2.new(0, sideX, 0, currentY)
	end
end

