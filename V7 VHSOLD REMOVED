local function applySelection(btns, selected)
	for i, bb in ipairs(btns) do
		bb.btn.BackgroundColor3 = i == selected and Color3.fromRGB(40, 25, 80) or Color3.fromRGB(22, 18, 40)
		bb.stroke.Color = i == selected and Color3.fromRGB(140, 90, 255) or Color3.fromRGB(70, 50, 120)
		bb.btn.TextColor3 = i == selected and Color3.fromRGB(230, 210, 255) or Color3.fromRGB(190, 180, 220)
	end
end

