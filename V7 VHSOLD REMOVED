local function applyFlSettings()
	fl.Brightness = flSettings.brightness
	lightPart.Reflectance = flSettings.reflectance
	if flSettings.blendColors then
		local a = Lighting.Ambient
		fl.Color = Color3.new(
			(flSettings.color.R + a.R) / 2,
			(flSettings.color.G + a.G) / 2,
			(flSettings.color.B + a.B) / 2
		)
	else
		fl.Color = flSettings.color
	end
end

