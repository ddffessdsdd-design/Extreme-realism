local function updateStatus()
	local parts = {}
	if vhsEnabled        then table.insert(parts, "◈ VHS") end
	if analogEnabled     then table.insert(parts, "◈ ANALOG") end
	if urEnabled         then table.insert(parts, "◈ UR") end
	if untitledEnabled   then table.insert(parts, "◈ UNTITLED") end
	if flashlightEnabled then table.insert(parts, "◈ FL") end
	if motionBlurEnabled then table.insert(parts, "◈ MB") end
	if guiHidden         then table.insert(parts, "◈ HIDE") end
	if not scriptEnabled then table.insert(parts, "◈ OFF") end
	statusLabel.Text = #parts > 0 and table.concat(parts, "  ") or "None"
end

local function setState(btn, dot, stroke, on, label)
	btn.BackgroundColor3 = on and Color3.fromRGB(40, 25, 80) or Color3.fromRGB(22, 18, 40)
	dot.BackgroundColor3 = on and Color3.fromRGB(160, 120, 255) or Color3.fromRGB(80, 60, 120)
	stroke.Color = on and Color3.fromRGB(150, 100, 255) or Color3.fromRGB(80, 60, 130)
	btn.TextColor3 = on and Color3.fromRGB(230, 210, 255) or Color3.fromRGB(200, 190, 230)
	btn.Text = "  " .. label
end

