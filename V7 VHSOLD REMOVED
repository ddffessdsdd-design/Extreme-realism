btnToggle.MouseButton1Click:Connect(function()
	scriptEnabled = not scriptEnabled
	if not scriptEnabled then
		resetShaders()
		flashlightEnabled = false; fl.Enabled = false
		motionBlurEnabled = false; motionBlur.Size = 0
		flMenuOpen = false; flPanel.Visible = false
		mbMenuOpen = false; mbPanel.Visible = false
		applyLighting("Reset")
		if guiHidden then
			guiHidden = false; toggleGuiVisibility(false)
			setState(btnHideUI, dotHideUI, sHide, false, "HIDE UI")
		end
		setState(btnFL,     dotFL,     sFL,     false, "FLASHLIGHT ▸")
		setState(btnMB,     dotMB,     sMB,     false, "MOTION BLUR ▸")
		setState(btnToggle, dotToggle, sToggle, false, "DISABLED")
	else
		applyLighting("Normal")
		setState(btnToggle, dotToggle, sToggle, true, "ENABLED")
	end
	updateStatus()
end)

