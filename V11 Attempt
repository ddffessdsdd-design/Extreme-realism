local function getEffects()
	local cc = safeFindChild(Lighting, "MainCC") or Instance.new("ColorCorrectionEffect", Lighting)
	cc.Name = "MainCC"
	local bloom = safeFindChild(Lighting, "MainBloom") or Instance.new("BloomEffect", Lighting)
	bloom.Name = "MainBloom"
	return cc, bloom
end

local function applyFlSettings()
	fl.Brightness = flSettings.brightness
	fl.Range = flSettings.range
	if flSettings.blendColors then
		local a = Lighting.Ambient
		fl.Color = Color3.new((flSettings.color.R+a.R)/2, (flSettings.color.G+a.G)/2, (flSettings.color.B+a.B)/2)
	else
		fl.Color = flSettings.color
	end
end

local applyLighting
local applyMode

applyLighting = function(mode)
	local cc, bloom = getEffects()
	local cfg = modeConfigs[mode] or modeConfigs.Normal

	effectGui.Enabled = mode ~= "Normal"
	hideAllOverlays()
	Lighting.Technology = Enum.Technology.ShadowMap

	cc.Enabled = true; bloom.Enabled = true

	local sat = cfg.saturation; local con = cfg.contrast
	local bri = cfg.brightness; local exp = cfg.exposure
	local bi = cfg.bloomIntensity; local bt = cfg.bloomThreshold; local bs = cfg.bloomSize

	if mode == "VHS" then sat = vhsSettings.saturation; con = vhsSettings.contrast; exp = vhsSettings.exposure
	elseif mode == "analog" then sat = ahSettings.saturation; con = ahSettings.contrast; bi = ahSettings.bloom
	elseif mode == "pressure" then
		pressureTint.Visible = true
		pressureTint.BackgroundColor3 = Color3.fromRGB(55,10,10)
		pressureTint.BackgroundTransparency = 0.75-(pressureIntensity*0.06)
		cc.TintColor = Color3.fromRGB(140,35,35)
		cc.Saturation = -0.75; cc.Contrast = 0.62+(pressureIntensity*0.10)
		cc.Brightness = -0.20-(pressureIntensity*0.07)
		Lighting.ExposureCompensation = -0.90-(pressureIntensity*0.12)
		bloom.Intensity = 0.85+(pressureIntensity*0.15)
		bwGlow.Visible = false; return
	elseif mode == "bw" then
		bwGlow.Visible = true
		bwGlow.BackgroundTransparency = 0.95-(bwBrightness*0.02)
		cc.TintColor = Color3.fromRGB(255,255,255)
		cc.Saturation = -1; cc.Contrast = 0.95+bwContrast
		cc.Brightness = 0.18+bwBrightness
		Lighting.ExposureCompensation = 0.12; bloom.Intensity = 0.10; return
	end

	cc.TintColor = cfg.tint
	cc.Saturation = clamp(sat + customAdjust.saturation, -1, 1)
	cc.Contrast = clamp(con + customAdjust.contrast, -1, 1)
	cc.Brightness = clamp(bri + customAdjust.brightness, -1, 1)
	Lighting.ExposureCompensation = clamp(exp + customAdjust.exposure, -5, 5)
	bloom.Intensity = math.max(0, bi + customAdjust.bloom)
	bloom.Threshold = clamp(bt, 0, 1)
	bloom.Size = math.max(0, bs)

	for overlayName, isVisible in pairs(cfg.overlays or {}) do
		setOverlayVisibility(overlayName, isVisible)
	end

	if mode == "Normal" then
		effectGui.Enabled = false; cc.Enabled = false; bloom.Enabled = false
		Lighting.ExposureCompensation = 0; hideAllOverlays()
	end
end

applyMode = function(mode)
	currentMode = mode
	vhsEnabled = (mode=="VHS"); analogEnabled = (mode=="analog"); urEnabled = (mode=="UR")
	untitledEnabled = (mode=="untitled"); pressureEnabled = (mode=="pressure"); bwEnabled = (mode=="bw")
	crtEnabled = (mode=="crt"); nightVisionEnabled = (mode=="nightVision"); thermalEnabled = (mode=="thermal")
	foundFootageEnabled = (mode=="foundFootage")
	applyLighting(mode)
end

-- ============================================================
-- GUI HIDE FUNCTION
-- Sets transparency of ALL non-shader GUI to 1 (does not delete)
-- Covers: ScreenGui, GuiObjects, SurfaceGui, Highlights, UIStroke
-- Ignores: CoreGui, ShaderPanel, ShaderOverlays, ShaderControl
-- ============================================================
local hiddenSnapshots = {}
local shaderGuiNames = { ShaderPanel = true, ShaderOverlays = true, ShaderControl = true }

local function isShaderGui(obj)
	if not obj then return false end
	-- Walk up to find the ScreenGui root
	local current = obj
	while current and current ~= playerGui and current ~= workspace do
		if shaderGuiNames[current.Name] then return true end
		current = current.Parent
	end
	return false
end

local function toggleGuiVisibility(hide)
	local roots = { playerGui, workspace }
	if hide then
		for _, root in ipairs(roots) do
			for _, obj in ipairs(root:GetDescendants()) do
				if isShaderGui(obj) then continue end
				if obj:IsA("ScreenGui") then
					hiddenSnapshots[obj] = hiddenSnapshots[obj] or { enabled = obj.Enabled }
					obj.Enabled = false
				elseif obj:IsA("SurfaceGui") then
					hiddenSnapshots[obj] = hiddenSnapshots[obj] or { enabled = obj.Enabled }
					obj.Enabled = false
				elseif obj:IsA("Highlight") then
					hiddenSnapshots[obj] = hiddenSnapshots[obj] or { fill = obj.FillTransparency, outline = obj.OutlineTransparency }
					obj.FillTransparency = 1; obj.OutlineTransparency = 1
				elseif obj:IsA("GuiObject") then
					hiddenSnapshots[obj] = hiddenSnapshots[obj] or {
						bg = obj.BackgroundTransparency,
						txt = (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) and obj.TextTransparency or nil,
						img = (obj:IsA("ImageLabel") or obj:IsA("ImageButton")) and obj.ImageTransparency or nil,
					}
					obj.BackgroundTransparency = 1
					if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then obj.TextTransparency = 1 end
					if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then obj.ImageTransparency = 1 end
				elseif obj:IsA("UIStroke") then
					hiddenSnapshots[obj] = hiddenSnapshots[obj] or { thickness = obj.Thickness }
					obj.Thickness = 0
				end
			end
		end
	else
		for obj, data in pairs(hiddenSnapshots) do
			if obj and obj.Parent then
				if obj:IsA("UIStroke") then obj.Thickness = data.thickness or obj.Thickness
				elseif obj:IsA("ScreenGui") or obj:IsA("SurfaceGui") then obj.Enabled = data.enabled ~= false
				elseif obj:IsA("Highlight") then
					obj.FillTransparency = data.fill or obj.FillTransparency
					obj.OutlineTransparency = data.outline or obj.OutlineTransparency
				else
					obj.BackgroundTransparency = data.bg or obj.BackgroundTransparency
					if data.txt ~= nil then obj.TextTransparency = data.txt end
					if data.img ~= nil then obj.ImageTransparency = data.img end
				end
			end
		end
		hiddenSnapshots = {}
	end
end

-- ============================================================
-- VIEW BOBBING
-- ============================================================
local function getWalkShake(dt)
	if not viewBobbingEnabled then return CFrame.new() end
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	if not humanoid or not rootPart then return CFrame.new() end
	local vel = rootPart.AssemblyLinearVelocity
	local speed = Vector3.new(vel.X,0,vel.Z).Magnitude
	local moving = speed > 0.8 and humanoid.FloorMaterial ~= Enum.Material.Air
	shakeTime = shakeTime + dt * (moving and (7+speed*0.18) or 1.8)
	local bobAmp = clamp(viewBobbingIntensity,0,1)
	if not moving then
		return CFrame.new(math.sin(shakeTime*0.8)*(0.006+bobAmp*0.004), math.sin(shakeTime*1.15)*(0.010+bobAmp*0.010), 0)
	end
	local amp = bobAmp * 0.012
	return CFrame.new(math.sin(shakeTime*6.3)*(0.010+amp), -math.abs(math.sin(shakeTime*9.0))*(0.016+amp*1.7), math.sin(shakeTime*4.2)*(0.008+amp*0.8))
		* CFrame.Angles(0, 0, math.sin(shakeTime*5.0)*math.rad(0.25+(amp*55)))
end

-- ============================================================
-- PROFILE SAVE / LOAD
-- ============================================================
local function sanitizeProfileName(name)
	name = tostring(name or ""):gsub("^%s+",""):gsub("%s+$",""):gsub("[^%w%-%_ ]","_")
	return name == "" and autoProfileName or name
end

local function buildProfileData()
	return {
		version=1, currentMode=currentMode, scriptEnabled=scriptEnabled,
		viewBobbingEnabled=viewBobbingEnabled, viewBobbingIntensity=viewBobbingIntensity,
		bwBrightness=bwBrightness, bwContrast=bwContrast, pressureIntensity=pressureIntensity,
		flashlightEnabled=flashlightEnabled, motionBlurEnabled=motionBlurEnabled,
		flSettings={ brightness=flSettings.brightness, heaviness=flSettings.heaviness, range=flSettings.range,
			blendColors=flSettings.blendColors, color={R=flSettings.color.R,G=flSettings.color.G,B=flSettings.color.B} },
		mbSettings={strength=mbSettings.strength, speed=mbSettings.speed},
		vhsSettings={contrast=vhsSettings.contrast, saturation=vhsSettings.saturation, exposure=vhsSettings.exposure},
		ahSettings={contrast=ahSettings.contrast, saturation=ahSettings.saturation, bloom=ahSettings.bloom},
		customAdjust={saturation=customAdjust.saturation, contrast=customAdjust.contrast,
			brightness=customAdjust.brightness, bloom=customAdjust.bloom, exposure=customAdjust.exposure},
	}
end

local function saveProfile(profileName)
	profileName = sanitizeProfileName(profileName)
	local json = HttpService:JSONEncode(buildProfileData())
	if type(writefile)=="function" and type(isfolder)=="function" and type(makefolder)=="function" then
		pcall(function()
			if not isfolder(profileStorageFolder) then makefolder(profileStorageFolder) end
			writefile(profileStorageFolder.."/"..profileName..".json", json)
		end)
	else
		savedProfiles[profileName] = json
	end
end

local function loadProfile(profileName)
	profileName = sanitizeProfileName(profileName)
	local json
	if type(readfile)=="function" and type(isfile)=="function" then
		local ok, result = pcall(function()
			if isfile(profileStorageFolder.."/"..profileName..".json") then
				return readfile(profileStorageFolder.."/"..profileName..".json")
			end
		end)
		if ok then json = result end
	end
	json = json or savedProfiles[profileName]
	if not json then return false end
	local ok, data = pcall(function() return HttpService:JSONDecode(json) end)
	if not ok or type(data)~="table" then return false end
	isLoadingProfile = true
	currentMode = data.currentMode or "Normal"
	scriptEnabled = data.scriptEnabled ~= false
	viewBobbingEnabled = data.viewBobbingEnabled == true
	viewBobbingIntensity = tonumber(data.viewBobbingIntensity) or viewBobbingIntensity
	bwBrightness = tonumber(data.bwBrightness) or bwBrightness
	bwContrast = tonumber(data.bwContrast) or bwContrast
	pressureIntensity = tonumber(data.pressureIntensity) or pressureIntensity
	flashlightEnabled = data.flashlightEnabled == true
	motionBlurEnabled = data.motionBlurEnabled == true
	if type(data.customAdjust)=="table" then
		for k,v in pairs(data.customAdjust) do customAdjust[k] = tonumber(v) or customAdjust[k] end
	end
	if type(data.flSettings)=="table" then
		flSettings.brightness = tonumber(data.flSettings.brightness) or flSettings.brightness
		flSettings.heaviness = tonumber(data.flSettings.heaviness) or flSettings.heaviness
		flSettings.range = tonumber(data.flSettings.range) or flSettings.range
		flSettings.blendColors = data.flSettings.blendColors == true
		if type(data.flSettings.color)=="table" then
			flSettings.color = Color3.fromRGB(
				clamp(tonumber(data.flSettings.color.R) or 255,0,255),
				clamp(tonumber(data.flSettings.color.G) or 255,0,255),
				clamp(tonumber(data.flSettings.color.B) or 255,0,255))
		end
	end
	if type(data.mbSettings)=="table" then
		mbSettings.strength = tonumber(data.mbSettings.strength) or mbSettings.strength
		mbSettings.speed = tonumber(data.mbSettings.speed) or mbSettings.speed
	end
	if type(data.vhsSettings)=="table" then
		vhsSettings.contrast = tonumber(data.vhsSettings.contrast) or vhsSettings.contrast
		vhsSettings.saturation = tonumber(data.vhsSettings.saturation) or vhsSettings.saturation
		vhsSettings.exposure = tonumber(data.vhsSettings.exposure) or vhsSettings.exposure
	end
	if type(data.ahSettings)=="table" then
		ahSettings.contrast = tonumber(data.ahSettings.contrast) or ahSettings.contrast
		ahSettings.saturation = tonumber(data.ahSettings.saturation) or ahSettings.saturation
		ahSettings.bloom = tonumber(data.ahSettings.bloom) or ahSettings.bloom
	end
	applyFlSettings()
	applyMode(currentMode)
	fl.Enabled = flashlightEnabled
	if not motionBlurEnabled then motionBlur.Size = 0 end
	isLoadingProfile = false; profileDirty = false
	return true
end

