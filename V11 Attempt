-- ============================================================
-- RENDER LOOP
-- ============================================================
local prevCamCF = camera.CFrame
local smoothFlCFrame = CFrame.new()
local scanlineTimer = 0

local function refreshScanlines()
	local viewport = (camera and camera.ViewportSize) or Vector2.new(1280,720)
	local spacing = math.max(4, math.floor(viewport.Y / #scanlineBars))
	local offset = math.floor((tick()*20) % spacing)
	for i, bar in ipairs(scanlineBars) do
		bar.Size = UDim2.new(1,0,0,1)
		bar.Position = UDim2.new(0,0,0, ((i-1)*spacing+offset) % viewport.Y)
	end
end

RunService.RenderStepped:Connect(function(dt)
	if not scriptEnabled then return end

	-- Scanlines animation
	if effectGui.Enabled then
		scanlineTimer = scanlineTimer + dt
		if scanlineTimer >= 0.033 then
			scanlineTimer = 0
			refreshScanlines()
		end
		-- Chroma aberration drift
		if chromaRed.Visible then
			local t = tick()
			chromaRed.Position = UDim2.new(0, math.sin(t*0.7)*2, 0, 0)
			chromaBlue.Position = UDim2.new(0, math.cos(t*0.5)*(-2), 0, 0)
		end
	end

	-- Motion blur
	if motionBlurEnabled then
		local humanoid = character and character:FindFirstChildOfClass("Humanoid")
		local rootPart = character and character:FindFirstChild("HumanoidRootPart")
		if rootPart then
			local vel = rootPart.AssemblyLinearVelocity
			local speed = Vector3.new(vel.X,0,vel.Z).Magnitude
			motionBlur.Size = speed >= mbSettings.speed and mbSettings.strength or 0
		end
	end

	-- Flashlight follow camera
	if flashlightEnabled and camera then
		local targetCF = camera.CFrame
		smoothFlCFrame = smoothFlCFrame:Lerp(targetCF, 1 - flSettings.heaviness)
		lightPart.CFrame = smoothFlCFrame
	end

	-- View bobbing
	if viewBobbingEnabled and camera then
		local shake = getWalkShake(dt)
		camera.CFrame = camera.CFrame * shake
	end
end)

