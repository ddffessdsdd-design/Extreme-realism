-- HELPERS
-- ============================================================
local function clamp(v, minV, maxV)
	return math.max(minV, math.min(maxV, v))
end

local function safeFindChild(parent, name)
	return parent:FindFirstChild(name)
end

local function roundNumber(n, decimals)
	local p = 10 ^ (decimals or 0)
	return math.floor(n * p + 0.5) / p
end

local function detectDeviceMode()
	if UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled then
		return "Phone"
	end
	if UserInputService.TouchEnabled and UserInputService.KeyboardEnabled then
		return "Tablet"
	end
	return "PC"
end

