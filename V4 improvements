-- 3. PRO LIGHTING ENGINE
local function applyLighting(mode)
	local cc = Lighting:FindFirstChild("MainCC") or Instance.new("ColorCorrectionEffect", Lighting)
	cc.Name = "MainCC"; cc.Enabled = true
	local bloom = Lighting:FindFirstChild("URBloom") or Instance.new("BloomEffect", Lighting)
	bloom.Name = "URBloom"; bloom.Enabled = true

	vignette.Visible = (mode == "vhso")
	darkOverlay.Visible = (mode == "vhso")

	if mode == "Normal" then
		Lighting.Technology = Enum.Technology.Future
		cc.TintColor = Color3.new(1, 1, 1); cc.Saturation = -0.1; cc.Contrast = 0.3
		bloom.Intensity = 0.4; bloom.Threshold = 0.9
		Lighting.ExposureCompensation = 0
		grain.ImageTransparency = 0.94

	elseif mode == "vhso" then
		Lighting.Technology = Enum.Technology.Future
		cc.Contrast = 0.6
		cc.Saturation = -0.85
		cc.TintColor = Color3.fromRGB(200, 210, 230)
		bloom.Intensity = 2.5
		bloom.Threshold = 0.3
		bloom.Size = 56
		Lighting.ExposureCompensation = -2.5
		grain.ImageTransparency = 0.55

	elseif mode == "UR" then
		cc.Contrast = 0.55; cc.Saturation = 0.15; cc.TintColor = Color3.fromRGB(240, 245, 255)
		bloom.Intensity = 1.2; bloom.Size = 24; bloom.Threshold = 0.8

	elseif mode == "VHS" then
		cc.Contrast = 0.95; cc.Saturation = -1; cc.TintColor = Color3.new(1, 1, 1)

	elseif mode == "Reset" then
		Lighting.Technology = Enum.Technology.ShadowMap
		cc.Enabled = false; bloom.Enabled = false
		Lighting.ExposureCompensation = 0
		grain.ImageTransparency = 0.94
	end
end

applyLighting("Normal")

-- 4. GUI VISIBILITY SYSTEM (!rg)
local guiSnapshot = {}
local function toggleGuiVisibility(hide)
	if hide then
		for _, gui in pairs(playerGui:GetDescendants()) do
			if gui:IsA("GuiObject") and not gui:IsDescendantOf(effectGui) then
				guiSnapshot[gui] = {
					bg = gui.BackgroundTransparency,
					txt = (gui:IsA("TextLabel") or gui:IsA("TextButton")) and gui.TextTransparency or nil,
					img = (gui:IsA("ImageLabel") or gui:IsA("ImageButton")) and gui.ImageTransparency or nil
				}
				gui.BackgroundTransparency = 1
				if guiSnapshot[gui].txt then gui.TextTransparency = 1 end
				if guiSnapshot[gui].img then gui.ImageTransparency = 1 end
			end
		end
	else
		for gui, s in pairs(guiSnapshot) do
			if gui and gui.Parent then
				gui.BackgroundTransparency = s.bg
				if s.txt then gui.TextTransparency = s.txt end
				if s.img then gui.ImageTransparency = s.img end
			end
		end
		guiSnapshot = {}
	end
end

-- 5. WALK SHAKE SYSTEM
local shakeTime = 0
local SHAKE_SPEED  = 9      -- How fast the bob cycles
local SHAKE_SWAY   = 0.045  -- Left/right sway amount
local SHAKE_BOB    = 0.03   -- Up/down bob amount
local SHAKE_TILT   = 0.6    -- Camera roll tilt (degrees)
local SPEED_THRESHOLD = 0.5 -- Studs/s needed to trigger shake

local function getWalkShake(dt)
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not rootPart or not humanoid then return CFrame.new() end

	local vel = rootPart.AssemblyLinearVelocity
	local speed = Vector3.new(vel.X, 0, vel.Z).Magnitude
	local onGround = humanoid.FloorMaterial ~= Enum.Material.Air

	if speed > SPEED_THRESHOLD and onGround then
		shakeTime = shakeTime + dt * SHAKE_SPEED
		local sway = math.sin(shakeTime)      * SHAKE_SWAY
		local bob  = math.abs(math.sin(shakeTime)) * SHAKE_BOB
		local tilt = math.sin(shakeTime)      * math.rad(SHAKE_TILT)
		return CFrame.new(sway, -bob, 0) * CFrame.Angles(0, 0, tilt)
	else
		-- Dampen shakeTime so re-entry feels natural
		shakeTime = shakeTime + dt * 2
		return CFrame.new()
	end
end

