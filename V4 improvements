-- 6. COMMANDS
local function disableScript()
	scriptEnabled = false
	effectGui.Enabled = false
	fl.Enabled = false
	applyLighting("Reset")
	toggleGuiVisibility(false)
end

local function enableScript()
	scriptEnabled = true
	applyLighting("Normal")
end

player.Chatted:Connect(function(msg)
	local lowMsg = msg:lower()

	if lowMsg == "!cl" then
		-- Updated command list
		print("--- !es / !enable, !ds / !disable, !fl, !rg, !vhs, !vhso, !ur ---")

	-- DISABLE: both !ds and !disable work
	elseif lowMsg == "!ds" or lowMsg == "!disable" then
		disableScript()

	-- ENABLE: both !es and !enable work
	elseif lowMsg == "!es" or lowMsg == "!enable" then
		enableScript()

	elseif scriptEnabled then
		if lowMsg == "!ur" then
			urEnabled = not urEnabled; vhsEnabled = false; vhsoEnabled = false
			effectGui.Enabled = urEnabled; applyLighting(urEnabled and "UR" or "Normal")

		elseif lowMsg == "!vhso" then
			vhsoEnabled = not vhsoEnabled; urEnabled = false; vhsEnabled = false
			effectGui.Enabled = vhsoEnabled
			fl.Enabled = vhsoEnabled
			applyLighting(vhsoEnabled and "vhso" or "Normal")

		elseif lowMsg == "!vhs" then
			vhsEnabled = not vhsEnabled; urEnabled = false; vhsoEnabled = false
			effectGui.Enabled = vhsEnabled; applyLighting(vhsEnabled and "VHS" or "Normal")

		elseif lowMsg == "!fl" then
			fl.Enabled = not fl.Enabled

		elseif lowMsg == "!rg" then
			toggleGuiVisibility(next(guiSnapshot) == nil)
		end
	end
end)

-- 7. CORE LOOP
RunService.RenderStepped:Connect(function(dt)
	if not scriptEnabled then return end

	-- Get walk shake this frame
	local shakeCF = getWalkShake(dt)

	-- Flashlight follows camera with shake applied
	lightPart.CFrame = lightPart.CFrame:Lerp(camera.CFrame * shakeCF, 0.18)

	-- Apply walk shake to camera
	camera.CFrame = camera.CFrame * shakeCF

	-- Grain animation
	if effectGui.Enabled then
		grain.ImageRectOffset = Vector2.new(math.random(0, 512), math.random(0, 512))
	end
end)
