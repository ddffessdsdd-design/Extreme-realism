	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)
UserInputService.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
		or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		panel.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end
end)

-- CORE LOOP
local grainTimer = 0
RunService.RenderStepped:Connect(function(dt)
	if not scriptEnabled then return end
	local shakeCF = getWalkShake(dt)
	if fl.Enabled then lightPart.CFrame = camera.CFrame end
	camera.CFrame = camera.CFrame * shakeCF
	if effectGui.Enabled then
		grainTimer = grainTimer + dt
		if grainTimer >= 0.07 then
			grainTimer = 0
			grain.ImageRectOffset = Vector2.new(math.random(0, 512), math.random(0, 512))
		end
		if vhsoEnabled then
			local drift = math.sin(tick() * 3) * 2
			chromaRed.Position = UDim2.new(0, -3 + drift, 0, 0)
			chromaBlue.Position = UDim2.new(0, 3 - drift, 0, 0)
		end
	end
end)
