-- GUI HIDE SYSTEM (now defined AFTER mainGui exists)
local guiSnapshot = {}
local function toggleGuiVisibility(hide)
	if hide then
		for _, obj in pairs(playerGui:GetDescendants()) do
			if obj:IsDescendantOf(effectGui) then continue end
			if obj:IsDescendantOf(mainGui) then continue end  -- skip shader panel

			if obj:IsA("GuiObject") then
				guiSnapshot[obj] = {
					bg  = obj.BackgroundTransparency,
					txt = (obj:IsA("TextLabel") or obj:IsA("TextButton")) and obj.TextTransparency or nil,
					img = (obj:IsA("ImageLabel") or obj:IsA("ImageButton")) and obj.ImageTransparency or nil
				}
				obj.BackgroundTransparency = 1
				if guiSnapshot[obj].txt then obj.TextTransparency = 1 end
				if guiSnapshot[obj].img then obj.ImageTransparency = 1 end
			elseif obj:IsA("UIStroke") then
				guiSnapshot[obj] = { thickness = obj.Thickness }
				obj.Thickness = 0
			end
		end
	else
		for obj, s in pairs(guiSnapshot) do
			if obj and obj.Parent then
				if obj:IsA("UIStroke") then
					obj.Thickness = s.thickness
				else
					obj.BackgroundTransparency = s.bg
					if s.txt then obj.TextTransparency = s.txt end
					if s.img then obj.ImageTransparency = s.img end
				end
			end
		end
		guiSnapshot = {}
	end
end

