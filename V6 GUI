local function updateStatus()
	local parts = {}
	if vhsEnabled        then table.insert(parts, "◈ VHS") end
	if vhsoEnabled       then table.insert(parts, "◈ VHS OLD") end
	if urEnabled         then table.insert(parts, "◈ ULTRA REAL") end
	if flashlightEnabled then table.insert(parts, "◈ FLASHLIGHT") end
	if guiHidden         then table.insert(parts, "◈ HIDE UI") end
	if not scriptEnabled then table.insert(parts, "◈ DISABLED") end
	statusLabel.Text = #parts > 0 and table.concat(parts, "\n") or "None"
end

local function setState(btn, dot, stroke, on, label)
	btn.BackgroundColor3 = on and Color3.fromRGB(40, 25, 80) or Color3.fromRGB(22, 18, 40)
	dot.BackgroundColor3 = on and Color3.fromRGB(160, 120, 255) or Color3.fromRGB(80, 60, 120)
	stroke.Color = on and Color3.fromRGB(150, 100, 255) or Color3.fromRGB(80, 60, 130)
	btn.TextColor3 = on and Color3.fromRGB(230, 210, 255) or Color3.fromRGB(200, 190, 230)
	btn.Text = "  " .. label
end

